  animalLotId           String?
  campaignId            String?
  linkedTreatmentId     String?
  reportFileName        String?
  reportMimeType        String?
  reportPath            String?
  notes                 String?
  recordedBy            String
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

