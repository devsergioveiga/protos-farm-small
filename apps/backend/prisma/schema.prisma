enum ExamMethod {
  LABORATORY
  FIELD
  IMAGING
}

enum ExamStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ResultIndicator {
  NORMAL
  ABOVE
  BELOW
  POSITIVE
  NEGATIVE
}

model ExamType {
