// ─── Core Models ─────────────────────────────────────────────────────

model Organization {
  id        String           @id @default(uuid())
  name      String
  type      OrganizationType
  document  String           @unique
  plan      String           @default("basic")
  status    OrgStatus        @default(ACTIVE)
  maxUsers  Int              @default(10)
  maxFarms  Int              @default(5)
  allowMultipleSessions Boolean @default(true)
  allowSocialLogin     Boolean @default(true)
  funruralBasis        FunruralBasis @default(PAYROLL)
  accountantName          String?
  accountantCrc           String?   @db.VarChar(20)
  accountantCpf           String?   @db.VarChar(14)
  integratedReportNotes   String?   @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  users       User[]
  farms       Farm[]
  customRoles CustomRole[]
  producers   Producer[]
  breeds      Breed[]
  cultivars           Cultivar[]
  moistureStandards   MoistureStandard[]
  grainDiscountTables GrainDiscountTable[]
  grainClassifications GrainClassification[]
  pests           Pest[]
  operationTypes            OperationType[]
  cropOperationSequences    CropOperationSequence[]
  operationTypeSchedules    OperationTypeSchedule[]
  cropPhenologicalStages    CropPhenologicalStage[]
  measurementUnits          MeasurementUnit[]
  unitConversions           UnitConversion[]
  productUnitConfigs        ProductUnitConfig[]
  products                  Product[]
  manufacturers             Manufacturer[]
  stockEntries              StockEntry[]
  stockBalances             StockBalance[]
  stockOutputs              StockOutput[]
  stockInventories          StockInventory[]
  stockAdjustments          StockAdjustment[]
  pesticidePrescriptions    PesticidePrescription[]
  diseases                  Disease[]
  treatmentProtocols        TreatmentProtocol[]
  sanitaryProtocols         SanitaryProtocol[]
  vaccinations              Vaccination[]
  dewormings                Deworming[]
  therapeuticTreatments     TherapeuticTreatment[]
  examTypes                ExamType[]
  animalExams              AnimalExam[]
  compositeProductions     CompositeProduction[]
  bulls                    Bull[]
  semenBatches             SemenBatch[]
  reproductiveReleases     ReproductiveRelease[]
  reproductiveCriteria     ReproductiveCriteria?
  heatRecords              HeatRecord[]
  matingPlans              MatingPlan[]
  iatfProtocols            IatfProtocol[]
  reproductiveLots         ReproductiveLot[]
  inseminations            Insemination[]
  naturalMatings           NaturalMating[]
  pregnancyDiagnoses       PregnancyDiagnosis[]
  calvingEvents            CalvingEvent[]
  calfSeparations          CalfSeparation[]
  weaningRecords           WeaningRecord[]
  weaningCriteria          WeaningCriteria?
  milkingRecords           MilkingRecord[]
  milkAnalyses             MilkAnalysis[]
  milkQualityConfig        MilkQualityConfig?
  mastitisCases            MastitisCase[]
  coolingTanks             CoolingTank[]
  milkCollections          MilkCollection[]
  dailyMilkProductions     DailyMilkProduction[]
  lactations               Lactation[]
  feedIngredients          FeedIngredient[]
  bromatologicalAnalyses   BromatologicalAnalysis[]
  diets                    Diet[]
  feedingRecords           FeedingRecord[]
  bankAccounts             BankAccount[]
  bankAccountBalances      BankAccountBalance[]
  financialTransactions    FinancialTransaction[]
  payables                 Payable[]
  receivables              Receivable[]
  accountTransfers         AccountTransfer[]
  creditCards              CreditCard[]
  creditCardBills          CreditCardBill[]
  creditCardExpenses       CreditCardExpense[]
  checks                   Check[]
  bankStatementImports     BankStatementImport[]
  bankStatementLines       BankStatementLine[]
  reconciliations          Reconciliation[]
  ruralCreditContracts     RuralCreditContract[]
  suppliers                Supplier[]
  purchaseRequests         PurchaseRequest[]
  approvalRules            ApprovalRule[]
  approvalActions          ApprovalAction[]
  delegations              Delegation[]
  notifications            Notification[]
  quotations               Quotation[]
  purchaseOrders           PurchaseOrder[]
  goodsReceipts            GoodsReceipt[]
  goodsReturns             GoodsReturn[]
  purchaseBudgets          PurchaseBudget[]
  notificationPreferences  NotificationPreference[]
  assets                   Asset[]
  depreciationConfigs      DepreciationConfig[]
  depreciationEntries      DepreciationEntry[]
  depreciationRuns         DepreciationRun[]
  animalExits              AnimalExit[]
  activeIngredients        ActiveIngredient[]
  productClasses           ProductClass[]
  storageLocations         StorageLocation[]
  maintenancePlans         MaintenancePlan[]
  workOrders               WorkOrder[]
  deferredMaintenances     DeferredMaintenance[]
  maintenanceProvisions    MaintenanceProvision[]
  assetDisposals           AssetDisposal[]
  assetFarmTransfers       AssetFarmTransfer[]
  assetInventories         AssetInventory[]
  assetRenovations         AssetRenovation[]
  assetWipStages           AssetWipStage[]
  assetWipContributions    AssetWipContribution[]
  assetTradeIns            AssetTradeIn[]
  assetLeasings            AssetLeasing[]
  biologicalAssetValuations BiologicalAssetValuation[]
  employees                Employee[]
  positions                Position[]
  workSchedules            WorkSchedule[]
  employeeContracts        EmployeeContract[]
  payrollRubricas          PayrollRubrica[]
  payrollLegalTables       PayrollLegalTable[]
  timeEntries              TimeEntry[]
  payrollRuns              PayrollRun[]
  salaryAdvances           SalaryAdvance[]
  epiProducts              EpiProduct[]
  epiDeliveries            EpiDelivery[]
  positionEpiRequirements  PositionEpiRequirement[]
  trainingRecords          TrainingRecord[]
  positionTrainingRequirements PositionTrainingRequirement[]
  medicalExams             MedicalExam[]
  taxGuides                TaxGuide[]
