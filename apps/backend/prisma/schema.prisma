// ─── EPIC-11 US-102: Vermifugação ───────────────────────────────────

model Deworming {
  id                    String              @id @default(uuid())
  organizationId        String
  farmId                String
  animalId              String
  productId             String?
  productName           String
  activeIngredient      String?             // princípio ativo
