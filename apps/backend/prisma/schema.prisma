model AnimalExam {
  id                    String       @id @default(uuid())
  organizationId        String
  farmId                String
  animalId              String
  examTypeId            String
  examTypeName          String
  collectionDate        DateTime     @db.Date
  sendDate              DateTime?    @db.Date
  laboratory            String?
  protocolNumber        String?
  status                ExamStatus   @default(PENDING)
  resultDate            DateTime?    @db.Date
  responsibleName       String
  veterinaryName        String?
  veterinaryCrmv        String?
  certificateNumber     String?
  certificateValidity   DateTime?    @db.Date
  animalLotId           String?
  campaignId            String?
  linkedTreatmentId     String?
  reportFileName        String?
  reportMimeType        String?
  reportPath            String?
  notes                 String?
  recordedBy            String
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  farm          Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal        Animal        @relation(fields: [animalId], references: [id], onDelete: Cascade)
  examType      ExamType      @relation(fields: [examTypeId], references: [id], onDelete: Restrict)
