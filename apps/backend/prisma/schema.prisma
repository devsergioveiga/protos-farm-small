  BIRTH
  INDUCTION
}

enum LactationStatus {
  IN_PROGRESS
  DRIED
}

enum DryingReason {
  SCHEDULED
  LOW_PRODUCTION
  TREATMENT
  ADVANCED_GESTATION
}

model Lactation {
