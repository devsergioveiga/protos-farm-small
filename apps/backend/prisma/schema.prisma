// ─── EPIC-13 US-119: Análise de Leite ────────────────────────────────

enum MilkAnalysisType {
  INDIVIDUAL_CMT
  INDIVIDUAL_LAB
  TANK
  OFFICIAL_RECORDING
}

model MilkAnalysis {
  id                  String            @id @default(uuid())
  organizationId      String
  farmId              String
  analysisType        MilkAnalysisType
  animalId            String?           // null for tank analysis
  analysisDate        DateTime          @db.Date
  laboratory          String?
  dairyCompany        String?           // for tank analysis
  // CMT results (CA2)
  cmtFrontLeft        String?           // NEGATIVE, TRACE, PLUS_1, PLUS_2, PLUS_3
  cmtFrontRight       String?
  cmtRearLeft         String?
  cmtRearRight        String?
  cmtAlert            Boolean           @default(false) // any quarter ++ or +++
  // Lab/Tank results (CA3, CA4)
  scc                 Float?            // cells/mL
  tbc                 Float?            // UFC/mL (tank only)
  fatPercent          Float?
  proteinPercent      Float?
  lactosePercent      Float?
  caseinPercent       Float?
  totalSolidsPercent  Float?
  snfPercent          Float?           // solids non-fat
  munMgDl             Float?            // milk urea nitrogen
  fatProteinRatio     Float?
  antibioticResidue   Boolean?          // tank only
  temperature         Float?            // tank only
  acidityDornic       Float?            // tank only
  cryoscopy           Float?            // tank only
  // Official recording (CA5)
  productionAmLiters  Float?
  productionPmLiters  Float?
  projected305Liters  Float?
  // Alerts (CA6)
  sccAlert            String?           // GREEN, YELLOW, RED
  tbcAlert            String?           // GREEN, YELLOW, RED
  // File
  reportFileName      String?
  reportPath          String?
  notes               String?
  recordedBy          String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  farm          Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal        Animal?      @relation(fields: [animalId], references: [id], onDelete: Cascade)
  recorder      User         @relation("MilkAnalysisRecorder", fields: [recordedBy], references: [id])

  @@index([organizationId])
  @@index([farmId])
  @@index([animalId])
  @@index([analysisDate])
  @@index([analysisType])
  @@map("milk_analyses")
}

model MilkQualityConfig {
  id                 String  @id @default(uuid())
  organizationId     String  @unique
  sccLimit           Float?  @default(500000)
  sccWarning         Float?  @default(400000)
  tbcLimit           Float?  @default(300000)
  tbcWarning         Float?  @default(200000)
  individualSccLimit Float?  @default(200000)
  // Bonus/penalty table (CA9)
  bonusTable         Json?   // [{parameter, ranges: [{min, max, bonusPerLiter}]}]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("milk_quality_configs")
}

// ─── EPIC-13 US-120: Mastite ─────────────────────────────────────────

enum MastitisGrade {
