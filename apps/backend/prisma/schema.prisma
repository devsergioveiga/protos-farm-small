  dosageMl              Float
  administrationRoute   AdministrationRoute
  productBatchNumber    String?
  productExpiryDate     DateTime?           @db.Date
  dewormingDate         DateTime            @db.Date
  responsibleName       String
  veterinaryName        String?
  protocolItemId        String?
  campaignId            String?
  opgPre                Int?                // OPG pré-vermifugação (CA3)
  opgPost               Int?                // OPG pós-vermifugação (CA3)
