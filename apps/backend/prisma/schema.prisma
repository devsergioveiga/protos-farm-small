  productId         String?  @map("product_id")
  stockOutputId     String?  @map("stock_output_id")
  totalQuantityUsed Decimal? @map("total_quantity_used") @db.Decimal(14, 4)

  farm        Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot   FieldPlot    @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  recorder    User         @relation("PesticideRecorder", fields: [recordedBy], references: [id])
  product     Product?     @relation("PesticideProduct", fields: [productId], references: [id], onDelete: SetNull)
