  creator      User         @relation("PBCreator", fields: [createdBy], references: [id])

  @@index([organizationId, periodStart, periodEnd])
  @@index([organizationId, category])
  @@map("purchase_budgets")
}

// ─── Assets (Cadastro de Ativos) ──────────────────────────────────────────────

enum AssetType {
  MAQUINA
  VEICULO
  IMPLEMENTO
  BENFEITORIA
  TERRA
}

enum AssetClassification {
  DEPRECIABLE_CPC27
  NON_DEPRECIABLE_CPC27
  FAIR_VALUE_CPC29
  BEARER_PLANT_CPC27
}

enum AssetStatus {
  ATIVO
  INATIVO
  EM_MANUTENCAO
  ALIENADO
  EM_ANDAMENTO
}

enum AssetDocumentType {
  CRLV
  SEGURO
  REVISAO
  CCIR
  ITR
  LAUDO
  GARANTIA
  OUTRO
}

enum AssetDisposalType {
  VENDA
  DESCARTE
  SINISTRO
  OBSOLESCENCIA
}

enum AssetInventoryStatus {
  DRAFT
  COUNTING
  RECONCILED
  CANCELLED
}

enum AssetRenovationDecision {
  CAPITALIZAR
  DESPESA
}

model Asset {
  id                   String              @id @default(uuid())
  organizationId       String
  farmId               String
  assetType            AssetType
  classification       AssetClassification
  status               AssetStatus         @default(ATIVO)
  name                 String
  description          String?
  assetTag             String
  acquisitionDate      DateTime?
  acquisitionValue     Decimal?            @db.Decimal(15, 2)
  supplierId           String?
  invoiceNumber        String?
  costCenterId         String?
  costCenterMode       String              @default("FIXED")
  costCenterPercent    Decimal?            @db.Decimal(5, 2)
  serialNumber         String?
  manufacturer         String?
  model                String?
  yearOfManufacture    Int?
  engineHp             Decimal?            @db.Decimal(8, 2)
  fuelType             String?
  renavamCode          String?
  licensePlate         String?
  parentAssetId        String?
  constructionMaterial String?
  areaM2               Decimal?            @db.Decimal(12, 2)
  capacity             String?
  geoPoint             Unsupported("geometry(Point, 4326)")?
  geoBoundary          Unsupported("geometry(Polygon, 4326)")?
  registrationNumber   String?
  areaHa               Decimal?            @db.Decimal(12, 4)
  carCode              String?
  currentHourmeter     Decimal?            @db.Decimal(12, 2)
  currentOdometer      Decimal?            @db.Decimal(12, 2)
  photoUrls            Json?               @default("[]")
  notes                String?
  disposalDate         DateTime?
  wipBudget            Decimal?            @db.Decimal(15, 2)
  wipBudgetAlertPct    Decimal?            @db.Decimal(5, 2)
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
