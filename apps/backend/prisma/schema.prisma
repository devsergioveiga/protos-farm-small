  tertiaryBull    Bull?      @relation("TertiaryBull", fields: [tertiaryBullId], references: [id], onDelete: SetNull)
  executedBull    Bull?      @relation("ExecutedBull", fields: [executedBullId], references: [id], onDelete: SetNull)

