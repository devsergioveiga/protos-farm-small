  plannedSire  Animal? @relation("PlannedSire", fields: [plannedSireId], references: [id], onDelete: SetNull)
  sire         Animal? @relation("SireReproductive", fields: [sireId], references: [id], onDelete: SetNull)
  calf         Animal? @relation("CalfRecord", fields: [calfId], references: [id], onDelete: SetNull)

  @@index([animalId])
  @@index([farmId])
  @@index([eventDate])
  @@index([type])
  @@map("animal_reproductive_records")
}

// ─── Cultivars ─────────────────────────────────────────────────────────────

enum CultivarType {
