}

enum DoseUnit {
  L_HA
  KG_HA
  ML_HA
  G_HA
}

model PesticideApplication {
  id                String          @id @default(uuid())
  farmId            String
  fieldPlotId       String
  appliedAt         DateTime
  productName       String
  activeIngredient  String
  dose              Decimal         @db.Decimal(10, 4)
  doseUnit          DoseUnit        @default(L_HA)
  sprayVolume       Decimal         @db.Decimal(10, 2)
  target            PesticideTarget
  targetDescription String?
  artNumber         String?
  agronomistCrea    String?
  technicalJustification String?
  temperature       Decimal?        @db.Decimal(5, 2)
  relativeHumidity  Decimal?        @db.Decimal(5, 2)
  windSpeed         Decimal?        @db.Decimal(5, 2)
  sprayerType       String?
  nozzleType        String?
  workingPressure   Decimal?        @db.Decimal(7, 2)
  applicationSpeed  Decimal?        @db.Decimal(5, 2)
  adjuvant          String?
  adjuvantDose      Decimal?        @db.Decimal(10, 4)
  tankMixOrder      String?
  tankMixPh         Decimal?        @db.Decimal(4, 2)
  withdrawalPeriodDays Int?
  safeHarvestDate   DateTime?
  notes             String?
  photoUrl          String?
  latitude          Decimal?        @db.Decimal(10, 7)
  longitude         Decimal?        @db.Decimal(10, 7)
