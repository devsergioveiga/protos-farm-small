// ─── Pest Library (MIP) ─────────────────────────────────────────────

enum InfestationLevel {
  AUSENTE
  BAIXO
  MODERADO
  ALTO
  CRITICO
}

enum PestCategory {
  INSETO
  ACARO
  FUNGO
  BACTERIA
  VIRUS
  NEMATOIDE
  PLANTA_DANINHA
  OUTRO
}

enum PestSeverity {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

model Pest {
  id              String        @id @default(uuid())
  organizationId  String
  commonName      String
  scientificName  String?
  category        PestCategory
  affectedCrops   String[]
  severity          PestSeverity?
  ndeDescription    String?
  ncDescription     String?
  controlThreshold  InfestationLevel? @map("control_threshold")
  recommendedProducts String?          @map("recommended_products")
  lifecycle       String?
  symptoms        String?
  photoUrl        String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  monitoringRecords MonitoringRecord[]

  @@unique([commonName, organizationId])
  @@index([organizationId])
  @@index([category])
  @@map("pests")
}

// ─── Monitoring Points (MIP) ──────────────────────────────────────────

model MonitoringPoint {
  id            String    @id @default(uuid())
