  @@index([farmId])
  @@index([animalId])
  @@index([productId])
  @@index([dewormingDate])
  @@index([campaignId])
  @@index([protocolItemId])
  @@index([animalId, chemicalGroup])
  @@map("dewormings")
}

// ─── EPIC-11 US-105: Tratamentos Terapêuticos ──────────────────────

enum TreatmentStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TreatmentOutcome {
  CURED
  PARTIAL_IMPROVEMENT
  DEATH
  CHRONIC
  REFERRED_DISPOSAL
}

enum EvolutionType {
  IMPROVEMENT
  STABLE
  WORSENING
}

enum ApplicationStatus {
  PENDING
  DONE
  NOT_DONE
}

model TherapeuticTreatment {
  id                     String              @id @default(uuid())
  organizationId         String
  farmId                 String
  animalId               String
  diseaseId              String?
  diseaseName            String
  diagnosisDate          DateTime            @db.Date
  observedSeverity       String              // MILD, MODERATE, SEVERE
  clinicalObservations   String?
  veterinaryName         String
  responsibleName        String
  treatmentProtocolId    String?
  treatmentProtocolName  String?
  withdrawalMeatDays     Int?
  withdrawalMilkDays     Int?
  withdrawalEndDate      DateTime?           @db.Date
  status                 TreatmentStatus     @default(OPEN)
  outcome                TreatmentOutcome?
  closedAt               DateTime?
  closingNotes           String?
  totalCostCents         Int                 @default(0)
  notes                  String?
  recordedBy             String
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  farm          Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal        Animal              @relation(fields: [animalId], references: [id], onDelete: Cascade)
  disease       Disease?            @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  protocol      TreatmentProtocol?  @relation(fields: [treatmentProtocolId], references: [id], onDelete: SetNull)
  recorder      User                @relation("TreatmentRecorder", fields: [recordedBy], references: [id])
  applications  TreatmentApplication[]
  evolutions    ClinicalEvolution[]

  @@index([organizationId])
  @@index([farmId])
  @@index([animalId])
  @@index([status])
  @@index([diagnosisDate])
  @@index([diseaseId])
  @@map("therapeutic_treatments")
}

model TreatmentApplication {
  id                    String              @id @default(uuid())
  treatmentId           String
  productId             String?
  productName           String
  dosage                Float
  dosageUnit            String              // MG_KG, ML_ANIMAL, FIXED_DOSE
  administrationRoute   AdministrationRoute
  scheduledDate         DateTime            @db.Date
  scheduledTime         String?             // "08:00"
  applicationDate       DateTime?           @db.Date
  applicationTime       String?
  status                ApplicationStatus   @default(PENDING)
  notDoneReason         String?
  responsibleName       String?
  stockOutputId         String?
  costCents             Int                 @default(0)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  treatment     TherapeuticTreatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  product       Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  stockOutput   StockOutput?         @relation(fields: [stockOutputId], references: [id], onDelete: SetNull)

  @@index([treatmentId])
  @@index([scheduledDate])
  @@index([status])
  @@map("treatment_applications")
}

model ClinicalEvolution {
  id                    String    @id @default(uuid())
  treatmentId           String
  evolutionDate         DateTime  @db.Date
  evolutionType         EvolutionType
  temperature           Float?
  observations          String?
  veterinaryName        String?
  recordedBy            String
  createdAt             DateTime  @default(now())

  treatment     TherapeuticTreatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  recorder      User                 @relation("EvolutionRecorder", fields: [recordedBy], references: [id])

  @@index([treatmentId])
  @@map("clinical_evolutions")
}

// ─── EPIC-11 US-106: Registro de Exames ─────────────────────────────

enum ExamCategory {
