// ─── Cultural Operations (US-040) ────────────────────────────────────────

enum CulturalOperationType {
  CAPINA_MANUAL
  ROCAGEM_MECANICA
  IRRIGACAO
  PODA
  DESBROTA
  RALEIO
  QUEBRA_VENTO
}

enum PruningType {
  ESQUELETAMENTO
  DECOTE
  RECEPA
}

model CulturalOperation {
  id                  String                @id @default(uuid())
  farmId              String
  fieldPlotId         String
  performedAt         DateTime
  operationType       CulturalOperationType

  // CA2 — duration & labor
  durationHours       Decimal?              @db.Decimal(6, 2)
  machineName         String?
  laborCount          Int?
  laborHours          Decimal?              @db.Decimal(6, 2)

  // CA3 — irrigation-specific
  irrigationDepthMm   Decimal?              @db.Decimal(8, 2)
  irrigationTimeMin   Decimal?              @db.Decimal(8, 2)
  irrigationSystem    String?

  // CA4 — pruning-specific
  pruningType         PruningType?
  pruningPercentage   Decimal?              @db.Decimal(5, 2)

  // CA5 — cost
  machineHourCost     Decimal?              @db.Decimal(10, 2)
  laborHourCost       Decimal?              @db.Decimal(10, 2)
  supplyCost          Decimal?              @db.Decimal(10, 2)

  // CA6 — photo & location
  notes               String?
  photoUrl            String?
  latitude            Decimal?              @db.Decimal(10, 7)
  longitude           Decimal?              @db.Decimal(10, 7)

  recordedBy          String
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot FieldPlot @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  recorder  User      @relation("CulturalOperationRecorder", fields: [recordedBy], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([performedAt])
  @@index([operationType])
  @@map("cultural_operations")
}

// ─── Field Teams (US-041) ─────────────────────────────────────────────────

enum FieldTeamType {
  COLHEITA_MANUAL
  APLICACAO_DEFENSIVOS
  CAPINA_ROCAGEM
  VACINACAO_MANEJO
  MANUTENCAO_CERCAS
  PLANTIO_MANUAL
  COLHEITA_CAFE
  COLHEITA_LARANJA
  GENERICA
}

model FieldTeam {
  id          String        @id @default(uuid())
  farmId      String
  name        String
  teamType    FieldTeamType
  isTemporary Boolean       @default(false)
  leaderId    String
  notes       String?
  createdBy   String
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  farm    Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  leader  User            @relation("TeamLeader", fields: [leaderId], references: [id])
  creator User            @relation("TeamCreator", fields: [createdBy], references: [id])
  members        FieldTeamMember[]
  teamOperations TeamOperation[]

  @@index([farmId])
  @@index([leaderId])
  @@index([teamType])
  @@map("field_teams")
}

model FieldTeamMember {
  id        String    @id @default(uuid())
  teamId    String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  team FieldTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@unique([teamId, userId, leftAt])
  @@index([teamId])
  @@index([userId])
  @@map("field_team_members")
}

// ─── Team Operations — Bulk (US-077) ──────────────────────────────────────

model TeamOperation {
  id             String          @id @default(uuid())
  farmId         String
  fieldPlotId    String
  teamId         String
  operationType  FieldOperationType
  performedAt    DateTime
  timeStart      DateTime
  timeEnd        DateTime
  notes          String?
  photoUrl       String?
