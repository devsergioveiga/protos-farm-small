// ─── Cultural Operations (US-040) ────────────────────────────────────────

enum CulturalOperationType {
  CAPINA_MANUAL
  ROCAGEM_MECANICA
  IRRIGACAO
  PODA
  DESBROTA
  RALEIO
  QUEBRA_VENTO
}

enum PruningType {
  ESQUELETAMENTO
  DECOTE
  RECEPA
}

model CulturalOperation {
  id                  String                @id @default(uuid())
  farmId              String
  fieldPlotId         String
  performedAt         DateTime
  operationType       CulturalOperationType

  // CA2 — duration & labor
  durationHours       Decimal?              @db.Decimal(6, 2)
  machineName         String?
  laborCount          Int?
  laborHours          Decimal?              @db.Decimal(6, 2)

  // CA3 — irrigation-specific
  irrigationDepthMm   Decimal?              @db.Decimal(8, 2)
  irrigationTimeMin   Decimal?              @db.Decimal(8, 2)
  irrigationSystem    String?

  // CA4 — pruning-specific
  pruningType         PruningType?
  pruningPercentage   Decimal?              @db.Decimal(5, 2)

  // CA5 — cost
  machineHourCost     Decimal?              @db.Decimal(10, 2)
  laborHourCost       Decimal?              @db.Decimal(10, 2)
  supplyCost          Decimal?              @db.Decimal(10, 2)

  // CA6 — photo & location
  notes               String?
  photoUrl            String?
  latitude            Decimal?              @db.Decimal(10, 7)
  longitude           Decimal?              @db.Decimal(10, 7)

  recordedBy          String
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot FieldPlot @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  recorder  User      @relation("CulturalOperationRecorder", fields: [recordedBy], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([performedAt])
  @@index([operationType])
  @@map("cultural_operations")
}

// ─── Soil Prep Operations (US-034) ───────────────────────────────────────

model SoilPrepOperation {
  id                  String    @id @default(uuid())
  farmId              String
  fieldPlotId         String
  operationTypeId     String?
  operationTypeName   String
  startedAt           DateTime
  endedAt             DateTime?

  // CA2 — machine, implement, operator, depth
  machineName         String?
  implementName       String?
  operatorName        String?
  depthCm             Decimal?  @db.Decimal(6, 2)

  // CA3 — inputs applied (JSON array)
  inputs              Json?     @default("[]")

  // CA5 — conditions
  soilMoisturePercent Decimal?  @db.Decimal(5, 2)
  weatherCondition    String?

  // CA7 — costs
  durationHours       Decimal?  @db.Decimal(6, 2)
  machineCostPerHour  Decimal?  @db.Decimal(10, 2)
  laborCount          Int?
  laborHourCost       Decimal?  @db.Decimal(10, 2)
  inputsCost          Decimal?  @db.Decimal(10, 2)

  // common
  notes               String?
  photoUrl            String?
  latitude            Decimal?  @db.Decimal(10, 7)
  longitude           Decimal?  @db.Decimal(10, 7)
  recordedBy          String
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Stock deduction (CA4)
  stockOutputId       String?  @map("stock_output_id")

  farm          Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot     FieldPlot      @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  operationType OperationType? @relation(fields: [operationTypeId], references: [id], onDelete: SetNull)
  recorder      User           @relation("SoilPrepRecorder", fields: [recordedBy], references: [id])
  stockOutput   StockOutput?   @relation("SoilPrepStockOutput", fields: [stockOutputId], references: [id], onDelete: SetNull)

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([startedAt])
  @@index([operationTypeId])
  @@index([stockOutputId])
  @@map("soil_prep_operations")
}

// ─── Field Teams (US-041) ─────────────────────────────────────────────────

enum FieldTeamType {
  COLHEITA_MANUAL
  APLICACAO_DEFENSIVOS
  CAPINA_ROCAGEM
  VACINACAO_MANEJO
  MANUTENCAO_CERCAS
  PLANTIO_MANUAL
  COLHEITA_CAFE
  COLHEITA_LARANJA
  GENERICA
}

// ─── Cost Centers (US-041 CA8) ────────────────────────────────────────────

model CostCenter {
  id             String    @id @default(uuid())
  farmId         String
  code           String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  farm       Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldTeams FieldTeam[]
  payableCostCenterItems    PayableCostCenterItem[]
  receivableCostCenterItems ReceivableCostCenterItem[]

  @@unique([farmId, code])
  @@index([farmId])
  @@map("cost_centers")
}

model FieldTeam {
  id           String        @id @default(uuid())
  farmId       String
  name         String
  teamType     FieldTeamType
  isTemporary  Boolean       @default(false)
  leaderId     String
  costCenterId String?
  notes        String?
  createdBy    String
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  farm       Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  leader     User            @relation("TeamLeader", fields: [leaderId], references: [id])
  creator    User            @relation("TeamCreator", fields: [createdBy], references: [id])
  costCenter CostCenter?     @relation(fields: [costCenterId], references: [id])
  members        FieldTeamMember[]
  teamOperations TeamOperation[]

  @@index([farmId])
  @@index([leaderId])
  @@index([teamType])
  @@index([costCenterId])
  @@map("field_teams")
}

model FieldTeamMember {
  id        String    @id @default(uuid())
  teamId    String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  team FieldTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@unique([teamId, userId, leftAt])
  @@index([teamId])
  @@index([userId])
  @@map("field_team_members")
}

// ─── Team Operations — Bulk (US-077) ──────────────────────────────────────

model TeamOperation {
  id             String          @id @default(uuid())
  farmId         String
  fieldPlotId    String
  teamId         String
  operationType  FieldOperationType
  performedAt    DateTime
  timeStart      DateTime
  timeEnd        DateTime
  notes          String?
  photoUrl       String?
  latitude       Decimal?        @db.Decimal(10, 7)
  longitude      Decimal?        @db.Decimal(10, 7)
  recordedBy     String
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot FieldPlot @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  team      FieldTeam @relation(fields: [teamId], references: [id])
  recorder  User      @relation("TeamOperationRecorder", fields: [recordedBy], references: [id])
  entries   TeamOperationEntry[]

  @@index([farmId])
  @@index([teamId])
  @@index([fieldPlotId])
  @@index([performedAt])
  @@map("team_operations")
}

// ─── Pest Library (MIP) ─────────────────────────────────────────────

enum InfestationLevel {
  AUSENTE
  BAIXO
  MODERADO
  ALTO
  CRITICO
}

enum PestCategory {
  INSETO
  ACARO
  FUNGO
  BACTERIA
  VIRUS
  NEMATOIDE
  PLANTA_DANINHA
  OUTRO
}

enum PestSeverity {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

model Pest {
  id              String        @id @default(uuid())
  organizationId  String
  commonName      String
  scientificName  String?
  category        PestCategory
  affectedCrops   String[]
  severity          PestSeverity?
  ndeDescription    String?
  ncDescription     String?
  controlThreshold  InfestationLevel? @map("control_threshold")
  recommendedProducts String?          @map("recommended_products")
  lifecycle       String?
  symptoms        String?
  photoUrl        String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  monitoringRecords MonitoringRecord[]

  @@unique([commonName, organizationId])
  @@index([organizationId])
  @@index([category])
  @@map("pests")
}

// ─── Monitoring Points (MIP) ──────────────────────────────────────────

model MonitoringPoint {
  id            String    @id @default(uuid())
  farmId        String
  fieldPlotId   String
  code          String
  latitude      Decimal   @db.Decimal(10, 7)
  longitude     Decimal   @db.Decimal(10, 7)
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot FieldPlot @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)

  monitoringRecords MonitoringRecord[]

  @@unique([fieldPlotId, code])
  @@index([farmId])
  @@index([fieldPlotId])
  @@map("monitoring_points")
}

// ─── Monitoring Records (MIP) ─────────────────────────────────────────

model MonitoringRecord {
  id                  String           @id @default(uuid())
  farmId              String
  fieldPlotId         String
  monitoringPointId   String
  pestId              String
  observedAt          DateTime
  infestationLevel    InfestationLevel
  sampleCount         Int?
  pestCount           Int?
  growthStage         String?
  hasNaturalEnemies   Boolean          @default(false)
  naturalEnemiesDesc  String?
  damagePercentage    Decimal?         @db.Decimal(5, 2)
  photoUrl            String?
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  farm            Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot       FieldPlot       @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  monitoringPoint MonitoringPoint @relation(fields: [monitoringPointId], references: [id], onDelete: Cascade)
  pest            Pest            @relation(fields: [pestId], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([monitoringPointId])
  @@index([pestId])
  @@index([observedAt])
  @@map("monitoring_records")
}

model TeamOperationEntry {
  id                String    @id @default(uuid())
  teamOperationId   String
  userId            String
  hoursWorked       Decimal?  @db.Decimal(6, 2)
  productivity      Decimal?  @db.Decimal(12, 4)
  productivityUnit  String?
  notes             String?
  createdAt         DateTime  @default(now())

  teamOperation TeamOperation @relation(fields: [teamOperationId], references: [id], onDelete: Cascade)
  user          User          @relation("TeamOperationEntryWorker", fields: [userId], references: [id])

  @@unique([teamOperationId, userId])
  @@index([teamOperationId])
  @@index([userId])
  @@map("team_operation_entries")
}

// ─── Productivity Targets (US-079 CA3) ─────────────────────────────

model ProductivityTarget {
  id              String          @id @default(uuid())
  farmId          String
  operationType   FieldOperationType
  targetValue     Decimal         @db.Decimal(12, 4)
  targetUnit      String
  period          String          @default("day")
  ratePerUnit     Decimal?        @db.Decimal(12, 4)
  rateUnit        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, operationType, targetUnit])
  @@index([farmId])
  @@map("productivity_targets")
}

// ─── Operation Types (US-081) ──────────────────────────────────────

model OperationType {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  parentId       String?   @map("parent_id")
  level          Int       @default(1)
  sortOrder      Int       @default(0) @map("sort_order")
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization        @relation(fields: [organizationId], references: [id])
  parent       OperationType?      @relation("OperationTypeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     OperationType[]     @relation("OperationTypeHierarchy")
  crops        OperationTypeCrop[]
  fields       OperationTypeField[]
  sequences    CropOperationSequence[]
  schedules    OperationTypeSchedule[]
  plantingOperations PlantingOperation[]
  soilPrepOperations SoilPrepOperation[]

  @@unique([name, parentId, organizationId])
  @@index([organizationId, parentId])
  @@index([organizationId, level])
  @@map("operation_types")
}

model OperationTypeCrop {
  id              String   @id @default(uuid())
  operationTypeId String   @map("operation_type_id")
  crop            String
  createdAt       DateTime @default(now()) @map("created_at")

  operationType OperationType @relation(fields: [operationTypeId], references: [id], onDelete: Cascade)

  @@unique([operationTypeId, crop])
  @@index([operationTypeId])
  @@map("operation_type_crops")
}

model OperationTypeField {
  id              String   @id @default(uuid())
  operationTypeId String   @map("operation_type_id")
  fieldKey        String   @map("field_key")
  visibility      String   @default("optional")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  operationType OperationType @relation(fields: [operationTypeId], references: [id], onDelete: Cascade)

  @@unique([operationTypeId, fieldKey])
  @@index([operationTypeId])
  @@map("operation_type_fields")
}

model CropOperationSequence {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  crop            String
  operationTypeId String   @map("operation_type_id")
  sequenceOrder   Int      @map("sequence_order")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  operationType OperationType @relation(fields: [operationTypeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, crop, operationTypeId])
  @@unique([organizationId, crop, sequenceOrder])
  @@index([organizationId, crop])
  @@map("crop_operation_sequences")
}

model OperationTypeSchedule {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  operationTypeId String   @map("operation_type_id")
  crop            String
  scheduleType    String   @map("schedule_type") // "fixed_date" | "phenological"
  startDay        Int?     @map("start_day") // 1-31 (fixed_date)
  startMonth      Int?     @map("start_month") // 1-12 (fixed_date)
  endDay          Int?     @map("end_day") // 1-31 (fixed_date)
  endMonth        Int?     @map("end_month") // 1-12 (fixed_date)
  phenoStage      String?  @map("pheno_stage") // nome da fase fenológica (phenological)
  offsetDays      Int?     @map("offset_days") // dias relativos ao evento/fase (phenological), negativo = antes
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  operationType OperationType @relation(fields: [operationTypeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, operationTypeId, crop])
  @@index([organizationId, crop])
  @@index([operationTypeId])
  @@map("operation_type_schedules")
}

model CropPhenologicalStage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  crop           String
  code           String   // ex: "VE", "V1", "R1", "Florada"
  name           String   // ex: "Emergência", "Primeira folha", "Florescimento"
  description    String?
  stageOrder     Int      @map("stage_order") // posição no ciclo da cultura
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, crop, code])
  @@unique([organizationId, crop, stageOrder])
  @@index([organizationId, crop])
  @@map("crop_phenological_stages")
}

model PlotPhenologicalRecord {
  id          String   @id @default(uuid())
  fieldPlotId String   @map("field_plot_id")
  crop        String
  stageCode   String   @map("stage_code")
  stageName   String   @map("stage_name")
  recordedAt  DateTime @default(now()) @map("recorded_at")
  recordedBy  String   @map("recorded_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  fieldPlot FieldPlot @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  recorder  User      @relation(fields: [recordedBy], references: [id])

  @@index([fieldPlotId, crop])
  @@index([fieldPlotId, recordedAt])
  @@map("plot_phenological_records")
}

// ─── Planting Operations (US-083) ─────────────────────────────────

model PlantingOperation {
  id                  String    @id @default(uuid())
  farmId              String
  fieldPlotId         String
  cultivarId          String?
  operationTypeId     String?
  seasonYear          String    // ex: "2025/2026"
  seasonType          SeasonType @default(SAFRA)

  // CA1 — basic required
  crop                String    // ex: "Soja", "Milho"
  plantingDate        DateTime  @db.Date
  plantedAreaPercent  Decimal   @default(100) @db.Decimal(5, 2) // CA9 — partial planting

  // CA2 — technical fields
  populationPerM      Decimal?  @db.Decimal(8, 2)  // seeds/m
  rowSpacingCm        Decimal?  @db.Decimal(6, 2)  // spacing between rows
  depthCm             Decimal?  @db.Decimal(6, 2)  // planting depth
  seedRateKgHa        Decimal?  @db.Decimal(8, 2)  // sowing rate kg/ha

  // CA3 — seed treatment (JSON array)
  seedTreatments      Json?     @default("[]")

  // CA4 — base fertilization (JSON array)
  baseFertilizations  Json?     @default("[]")

  // CA5 — machine & operator
  machineName         String?
  operatorName        String?
  averageSpeedKmH     Decimal?  @db.Decimal(6, 2)

  // CA8 — cost fields
  seedCost            Decimal?  @db.Decimal(12, 2)
  fertilizerCost      Decimal?  @db.Decimal(12, 2)
  treatmentCost       Decimal?  @db.Decimal(12, 2)
  operationCost       Decimal?  @db.Decimal(12, 2)

  // Stock deduction (US-096 CA3)
  seedProductId           String?   @map("seed_product_id")
  stockOutputId           String?   @map("stock_output_id")
  totalSeedQuantityUsed   Decimal?  @map("total_seed_quantity_used") @db.Decimal(14, 4)

  // common
  notes               String?
  photoUrl            String?
  latitude            Decimal?  @db.Decimal(10, 7)
  longitude           Decimal?  @db.Decimal(10, 7)
  recordedBy          String
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  farm          Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot     FieldPlot      @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  cultivar      Cultivar?      @relation(fields: [cultivarId], references: [id], onDelete: SetNull)
  operationType OperationType? @relation(fields: [operationTypeId], references: [id], onDelete: SetNull)
  recorder      User           @relation("PlantingRecorder", fields: [recordedBy], references: [id])
  seedProduct   Product?       @relation("PlantingSeedProduct", fields: [seedProductId], references: [id], onDelete: SetNull)
  stockOutput   StockOutput?   @relation("PlantingStockOutput", fields: [stockOutputId], references: [id], onDelete: SetNull)

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([cultivarId])
  @@index([plantingDate])
  @@index([operationTypeId])
  @@index([seedProductId])
  @@index([stockOutputId])
  @@map("planting_operations")
}

// ─── Grain Harvest (EPIC-09 / US-084) ──────────────────────────────

model GrainHarvest {
  id              String    @id @default(uuid())
  farmId          String
  fieldPlotId     String
  cultivarId      String?

  // CA1 — basic required fields
  crop            String    // ex: "Soja", "Milho", "Feijão", "Trigo"
  harvestDate     DateTime  @db.Date
  harvestedAreaHa Decimal   @db.Decimal(12, 4) // área colhida
  grossProductionKg Decimal @db.Decimal(14, 2) // produção bruta em kg
  moisturePct     Decimal   @db.Decimal(5, 2)  // umidade %
  impurityPct     Decimal   @db.Decimal(5, 2)  // impureza %

  // CA7 — múltiplas cargas por talhão
  loadNumber      Int       @default(0) // nº sequencial por talhão (auto)

  // CA4 — colheitadeira e operador
  harvesterName   String?   // nome/identificação da colheitadeira
  operatorName    String?   // nome do operador

  // CA5 — destino da produção
  destination       String?   // SILO_PROPRIO, ARMAZEM_TERCEIRO, VENDA_DIRETA
  destinationName   String?   // nome do silo/armazém/comprador
  romaneioNumber    String?   // nº romaneio (venda direta)

  // CA6 — pesagem
  grossWeightKg     Decimal?  @db.Decimal(14, 2) // peso bruto
  tareWeightKg      Decimal?  @db.Decimal(14, 2) // tara
  netWeightKg       Decimal?  @db.Decimal(14, 2) // peso líquido (calculado ou manual)
  weighingMethod    String?   // MANUAL, BALANCA

  // CA9 — custo de colheita
  harvesterHours      Decimal?  @db.Decimal(8, 2)  // horas de colheitadeira
  harvesterCostPerHour Decimal? @db.Decimal(12, 2) // R$/hora colheitadeira
  transhipmentCost    Decimal?  @db.Decimal(12, 2) // custo de transbordo (R$)
  transportCost       Decimal?  @db.Decimal(12, 2) // custo de transporte (R$)

  // common
  notes           String?
  recordedBy      String
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm          Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot     FieldPlot   @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  cultivar      Cultivar?   @relation(fields: [cultivarId], references: [id], onDelete: SetNull)
  recorder      User        @relation("GrainHarvestRecorder", fields: [recordedBy], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([cultivarId])
  @@index([harvestDate])
  @@map("grain_harvests")
}

// ─── Moisture Standards (EPIC-09 / US-084 CA3) ─────────────────────

model MoistureStandard {
  id              String    @id @default(uuid())
  organizationId  String
  crop            String    // ex: "Soja", "Milho" (normalizado uppercase)
  moisturePct     Decimal   @db.Decimal(5, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, crop])
  @@index([organizationId])
  @@map("moisture_standards")
}

// ─── Grain Discount Table (US-099 CA1+CA2) ──────────────────────────

model GrainDiscountTable {
  id              String    @id @default(uuid())
  organizationId  String
  crop            String    // ex: "SOJA", "MILHO" (normalizado uppercase)
  discountType    String    // MOISTURE, IMPURITY, DAMAGED
  thresholdPct    Decimal   @db.Decimal(5, 2) // limite de tolerância (ex: 14% umidade)
  discountPctPerPoint Decimal @db.Decimal(5, 4) // desconto % por ponto acima do threshold
  maxPct          Decimal?  @db.Decimal(5, 2) // limite máximo aceito (acima = rejeitado)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, crop, discountType])
  @@index([organizationId])
  @@map("grain_discount_tables")
}

// ─── Grain Classification (US-099 CA3) ──────────────────────────────

model GrainClassification {
  id              String    @id @default(uuid())
  organizationId  String
  crop            String    // ex: "SOJA", "MILHO"
  gradeType       String    // TIPO_1, TIPO_2, TIPO_3, FORA_DE_TIPO
  maxMoisturePct  Decimal   @db.Decimal(5, 2) // umidade máxima para esse tipo
  maxImpurityPct  Decimal   @db.Decimal(5, 2) // impureza máxima
  maxDamagedPct   Decimal   @db.Decimal(5, 2) // grãos avariados máximo
  maxBrokenPct    Decimal   @db.Decimal(5, 2) // quebrados/partidos máximo
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, crop, gradeType])
  @@index([organizationId])
  @@map("grain_classifications")
}

// ─── Coffee Harvest (EPIC-09 / US-085) ──────────────────────────────

model CoffeeHarvest {
  id              String    @id @default(uuid())
  farmId          String
  fieldPlotId     String
  cultivarId      String?

  // CA1 — campos básicos
  harvestDate     DateTime  @db.Date
  harvestType     String    // MECANIZADA, DERRICA_MANUAL, SELETIVA_CATACAO

  // CA2 — volume
  volumeLiters    Decimal   @db.Decimal(14, 2) // litros colhidos
  sacsBenefited   Decimal?  @db.Decimal(12, 2) // sacas de 60kg (café beneficiado)

  // CA3 — rendimento (litros por saca)
  yieldLitersPerSac Decimal? @db.Decimal(8, 2)

  // CA4 — classificação (% de cada tipo)
  cherryPct       Decimal   @default(0) @db.Decimal(5, 2) // % cereja
  greenPct        Decimal   @default(0) @db.Decimal(5, 2) // % verde
  floaterPct      Decimal   @default(0) @db.Decimal(5, 2) // % boia
  dryPct          Decimal   @default(0) @db.Decimal(5, 2) // % seco

  // CA5 — destino
  destination     String?   // TERREIRO, SECADOR_MECANICO, LAVADOR_SEPARADOR
  destinationName String?

  // CA6 — equipe de colheita
  numberOfHarvesters    Int?       // nº de colhedores
  harvestersProductivity Decimal?  @db.Decimal(10, 2) // litros/pessoa/dia

  // CA7 — café especial
  isSpecialLot    Boolean   @default(false)
  microlotCode    String?   // código de rastreabilidade do microlote

  // common
  notes           String?
  recordedBy      String
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm          Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot     FieldPlot   @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  cultivar      Cultivar?   @relation(fields: [cultivarId], references: [id], onDelete: SetNull)
  recorder      User        @relation("CoffeeHarvestRecorder", fields: [recordedBy], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([cultivarId])
  @@index([harvestDate])
  @@index([microlotCode])
  @@map("coffee_harvests")
}

model OrangeHarvest {
  id              String    @id @default(uuid())
  farmId          String
  fieldPlotId     String
  cultivarId      String?

  // CA1 — campos básicos
  harvestDate     DateTime  @db.Date
  variety         String?   // variedade da laranja (ex: Pera, Valência, Natal)

  // CA1 — produção
  numberOfBoxes   Decimal   @db.Decimal(12, 2) // nº de caixas (40,8kg)
  totalWeightKg   Decimal?  @db.Decimal(14, 2) // peso total em kg
  treesHarvested  Int?      // nº de árvores colhidas

  // CA2 — produtividade (calculados)
  boxesPerTree    Decimal?  @db.Decimal(8, 2) // caixas/pé
  boxesPerHa      Decimal?  @db.Decimal(10, 2) // cx/ha
  tonsPerHa       Decimal?  @db.Decimal(10, 2) // t/ha

  // CA3 — qualidade
  ratioSS         Decimal?  @db.Decimal(5, 2) // ratio sólidos solúveis (°Brix/acidez)
  acidityPct      Decimal?  @db.Decimal(5, 2) // acidez (%)
  refusalPct      Decimal?  @db.Decimal(5, 2) // % de refugo

  // CA4 — destino
  destination     String?   // INDUSTRIA, IN_NATURA, DESCARTE
  destinationName String?   // nome do comprador/indústria

  // CA5 — equipe
  numberOfHarvesters    Int?       // nº de colhedores
  harvestersProductivity Decimal?  @db.Decimal(10, 2) // caixas/pessoa/dia

  // CA6 — contrato de venda
  saleContractRef String?   // referência ao contrato de venda

  // common
  notes           String?
  recordedBy      String
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm          Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot     FieldPlot   @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  cultivar      Cultivar?   @relation(fields: [cultivarId], references: [id], onDelete: SetNull)
  recorder      User        @relation("OrangeHarvestRecorder", fields: [recordedBy], references: [id])

  @@index([farmId])
  @@index([fieldPlotId])
  @@index([cultivarId])
  @@index([harvestDate])
  @@index([saleContractRef])
  @@map("orange_harvests")
}

// ─── US-088: Unidades de Medida e Conversões ─────────────────────────

enum UnitCategory {
  WEIGHT
  VOLUME
  COUNT
  AREA
}

model MeasurementUnit {
  id             String       @id @default(uuid())
  organizationId String
  name           String       // kg, g, L, mL, unidade, saco, tonelada, arroba, caixa
  abbreviation   String       // kg, g, L, mL, un, sc, t, @, cx
  category       UnitCategory
  isSystem       Boolean      @default(false) // pré-configuradas, não deletáveis
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversionsFrom UnitConversion[] @relation("ConversionFromUnit")
  conversionsTo   UnitConversion[] @relation("ConversionToUnit")

  purchaseUnitConfigs    ProductUnitConfig[] @relation("PurchaseUnit")
  stockUnitConfigs       ProductUnitConfig[] @relation("StockUnit")
  applicationUnitConfigs ProductUnitConfig[] @relation("ApplicationUnit")
  productConvsFrom       ProductConversion[] @relation("ProductConvFromUnit")
  productConvsTo         ProductConversion[] @relation("ProductConvToUnit")
  products               Product[]

  // US-097: unidades de compra/estoque em itens de entrada
  entryItemsPurchaseUnit StockEntryItem[] @relation("EntryItemPurchaseUnit")
  entryItemsStockUnit    StockEntryItem[] @relation("EntryItemStockUnit")

  @@unique([organizationId, abbreviation])
  @@index([organizationId])
  @@index([category])
  @@map("measurement_units")
}

model UnitConversion {
  id             String  @id @default(uuid())
  organizationId String
  fromUnitId     String
  toUnitId       String
  factor         Decimal @db.Decimal(20, 10) // fromUnit * factor = toUnit
  isSystem       Boolean @default(false)
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromUnit     MeasurementUnit @relation("ConversionFromUnit", fields: [fromUnitId], references: [id], onDelete: Cascade)
  toUnit       MeasurementUnit @relation("ConversionToUnit", fields: [toUnitId], references: [id], onDelete: Cascade)

  @@unique([organizationId, fromUnitId, toUnitId])
  @@index([organizationId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("unit_conversions")
}

// CA3: Conversões específicas por produto
// CA4: Unidade de compra, estoque e aplicação por produto
model ProductUnitConfig {
  id                String  @id @default(uuid())
  organizationId    String
  productId         String  // FK será adicionada em US-089 (Product model)
  purchaseUnitId    String? // unidade de compra (ex: tonelada)
  stockUnitId       String? // unidade de estoque (ex: kg)
  applicationUnitId String? // unidade de aplicação (ex: mL/ha)
  densityGPerMl     Decimal? @db.Decimal(10, 4) // densidade para converter peso↔volume
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseUnit    MeasurementUnit? @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id], onDelete: SetNull)
  stockUnit       MeasurementUnit? @relation("StockUnit", fields: [stockUnitId], references: [id], onDelete: SetNull)
  applicationUnit MeasurementUnit? @relation("ApplicationUnit", fields: [applicationUnitId], references: [id], onDelete: SetNull)

  productConversions ProductConversion[]

  @@unique([organizationId, productId])
  @@index([organizationId])
  @@index([productId])
  @@map("product_unit_configs")
}

// CA3: Conversões específicas por produto (override das globais)
model ProductConversion {
  id                  String  @id @default(uuid())
  productUnitConfigId String
  fromUnitId          String
  toUnitId            String
  factor              Decimal @db.Decimal(20, 10)
  description         String? // ex: "480 L cereja = 1 saca beneficiada"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  productUnitConfig ProductUnitConfig @relation(fields: [productUnitConfigId], references: [id], onDelete: Cascade)
  fromUnit          MeasurementUnit   @relation("ProductConvFromUnit", fields: [fromUnitId], references: [id], onDelete: Cascade)
  toUnit            MeasurementUnit   @relation("ProductConvToUnit", fields: [toUnitId], references: [id], onDelete: Cascade)

  @@unique([productUnitConfigId, fromUnitId, toUnitId])
  @@index([productUnitConfigId])
  @@map("product_conversions")
}

// ─── EPIC-10 US-089: Produtos, Insumos e Serviços ─────────────────

enum ProductNature {
  PRODUCT
  SERVICE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id               String        @id @default(uuid())
  organizationId   String
  nature           ProductNature
  name             String
  type             String        // semente, fertilizante, defensivo, consultoria agronômica, etc.
  category         String?       // grupo/categoria livre
  status           ProductStatus @default(ACTIVE)
  notes            String?       // observações

  // ── Campos adicionais para Produto (CA5) ──
  commercialName   String?       // nome comercial
  manufacturerId   String?       // FK para Manufacturer
  measurementUnitId String?      // unidade de medida principal
  barcode          String?       // código de barras / SKU
  photoUrl         String?       // URL da foto
  technicalSheetUrl String?      // URL da ficha técnica (PDF)

  // ── Campos adicionais para Serviço (CA6) ──
  chargeUnit       String?       // hora, diária, visita, hectare, etc.
  unitCost         Decimal?      @db.Decimal(12, 2) // custo unitário padrão
  typicalFrequency String?       // avulso, mensal, quinzenal, semanal, por demanda
  requiresScheduling Boolean     @default(false)
  linkedActivity   String?       // pecuária de leite, café, milho, todas

  // ── CA8: Defensivos ──
  toxicityClass      String?     // I, II, III, IV, V (não classificado)
  mapaRegistration   String?     // nº registro MAPA
  environmentalClass String?     // I, II, III, IV
  actionMode         String?     // contato, sistêmico, translaminar, etc.
  chemicalGroup      String?     // organofosforado, piretroide, triazol, etc.
  withdrawalPeriods  Json?       // [{ crop, days }] — carência por cultura

  // ── CA9: Fertilizantes ──
  npkFormulation     String?     // ex: "04-14-08", "20-00-20"
  nutrientForm       String?     // granulado, líquido, foliar, fertirrigação
  solubility         String?     // alta, média, baixa, lenta liberação
  nutrientComposition Json?      // { N: 4, P2O5: 14, K2O: 8, ... } — % nutrientes

  // ── CA10: Foliares ──
  nutritionalComposition Json?   // { N: 10, P: 0, K: 5, Ca: 2, ... } — % ou g/L
  sprayCompatibility     Json?   // { compatible: [...], incompatible: [...] }

  // ── CA11: Medicamentos veterinários ──
  therapeuticClass     String?   // antibiótico, anti-inflamatório, antiparasitário, etc.
  administrationRoute  String?   // IM, SC, IV, oral, intramamária, intravaginal
  milkWithdrawalHours  Int?      // período de carência leite (horas)
  slaughterWithdrawalDays Int?   // período de carência abate (dias)
  vetMapaRegistration  String?   // registro MAPA vet
  requiresPrescription Boolean   @default(false)
  storageCondition     String?   // ambiente, refrigerado_2_8, congelado

  // ── US-092 CA1/CA2: Alertas de estoque ──
  reorderPoint       Decimal?  @map("reorder_point") @db.Decimal(14, 4) // ponto de reposição (quantidade mínima)
  safetyStock        Decimal?  @map("safety_stock") @db.Decimal(14, 4) // estoque de segurança (quantidade ideal)
  expiryAlertDays    Int?      @map("expiry_alert_days") // dias antes do vencimento para alertar (padrão: 30)

  // ── CA13-17: Produto Composto ──
  isComposite          Boolean   @default(false)
  compositeType        String?   // calda, mistura_fertilizante, racao_concentrado, pre_mistura_mineral, outro
  batchSize            Float?    // tamanho do lote padrão (ex: 1000 kg)
  batchUnit            String?   // unidade do lote (kg, L, etc.)

  // ── CA12: Sementes ──
  cultivarId           String?   // FK para Cultivar
  sieveSize            String?   // peneira
  industrialTreatment  String?   // tratamento industrial
  germinationPct       Decimal?  @db.Decimal(5, 2) // germinação %
  purityPct            Decimal?  @db.Decimal(5, 2) // pureza %

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?     // soft delete

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manufacturer     Manufacturer?    @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  measurementUnit  MeasurementUnit? @relation(fields: [measurementUnitId], references: [id], onDelete: SetNull)
  cultivar         Cultivar?        @relation(fields: [cultivarId], references: [id], onDelete: SetNull)

  compositions     ProductComposition[]
  compositeIngredients  CompositeIngredient[] @relation("CompositeIngredients")
  ingredientOf          CompositeIngredient[] @relation("IngredientOf")
  compositeProductions  CompositeProduction[] @relation("CompositeProductions")
  productionIngredients CompositeProductionItem[] @relation("ProductionIngredient")
  stockEntryItems      StockEntryItem[]
  stockOutputItems     StockOutputItem[]
  stockBalance         StockBalance?
  stockInventoryItems  StockInventoryItem[]
  stockAdjustments     StockAdjustment[]
  prescriptionProducts PesticidePrescriptionProduct[]
  pesticideApplications  PesticideApplication[]  @relation("PesticideProduct")
  fertilizerApplications FertilizerApplication[] @relation("FertilizerProduct")
  plantingOperations     PlantingOperation[]     @relation("PlantingSeedProduct")
  treatmentProtocolSteps TreatmentProtocolStep[]
  sanitaryProtocolItems  SanitaryProtocolItem[]
  vaccinations           Vaccination[]
  dewormings             Deworming[]
  treatmentApplications  TreatmentApplication[]
  iatfStepProducts       IatfProtocolStepProduct[] @relation("IatfStepProduct")
  mastitisApplications   MastitisApplication[]    @relation("MastitisProduct")

  @@unique([organizationId, name, nature])
  @@index([organizationId])
  @@index([organizationId, nature])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([manufacturerId])
  @@map("products")
}

model Manufacturer {
  id             String   @id @default(uuid())
  organizationId String
  name           String   // razão social
  cnpj           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("manufacturers")
}

// CA7: Composição / princípio ativo
model ProductComposition {
  id              String  @id @default(uuid())
  productId       String
  activeIngredient String  // nome do princípio ativo ou nutriente
  concentration   String? // ex: "480 g/L", "10%", "150 mg/mL"
  function        String? // ex: herbicida, bactericida, nutriente

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_compositions")
}

// ─── EPIC-10 US-089 CA13-CA17: Produto Composto ────────────────────

model CompositeIngredient {
  id                String    @id @default(uuid())
  compositeProductId String
  ingredientProductId String
  quantityPerBatch  Float     // quantity of ingredient per batch
  sortOrder         Int       @default(0)
  notes             String?
  createdAt         DateTime  @default(now())

  compositeProduct   Product  @relation("CompositeIngredients", fields: [compositeProductId], references: [id], onDelete: Cascade)
  ingredientProduct  Product  @relation("IngredientOf", fields: [ingredientProductId], references: [id], onDelete: Restrict)

  @@index([compositeProductId])
  @@index([ingredientProductId])
  @@map("composite_ingredients")
}

model CompositeProduction {
  id                  String    @id @default(uuid())
  organizationId      String
  compositeProductId  String
  productionDate      DateTime  @db.Date
  batchNumber         String?
  quantityProduced    Float
  totalCostCents      Int       @default(0)
  responsibleName     String
  notes               String?
  stockEntryId        String?   // stock entry for produced composite
  stockOutputId       String?   // stock output for ingredients consumed
  recordedBy          String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  compositeProduct  Product      @relation("CompositeProductions", fields: [compositeProductId], references: [id], onDelete: Cascade)
  recorder          User         @relation("CompositeProductionRecorder", fields: [recordedBy], references: [id])
  items             CompositeProductionItem[]

  @@index([organizationId])
  @@index([compositeProductId])
  @@index([productionDate])
  @@map("composite_productions")
}

model CompositeProductionItem {
  id                    String    @id @default(uuid())
  productionId          String
  ingredientProductId   String
  ingredientProductName String
  quantityUsed          Float
  unitCostCents         Int       @default(0)
  totalCostCents        Int       @default(0)
  sourceBatchNumber     String?
  createdAt             DateTime  @default(now())

  production        CompositeProduction @relation(fields: [productionId], references: [id], onDelete: Cascade)
  ingredientProduct Product             @relation("ProductionIngredient", fields: [ingredientProductId], references: [id], onDelete: Restrict)

  @@index([productionId])
  @@map("composite_production_items")
}

// ─── EPIC-10 US-090: Entrada de Insumos no Estoque ─────────────────

enum StockEntryStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum ExpenseType {
  FREIGHT
  INSURANCE
  UNLOADING
  TOLL
  TEMPORARY_STORAGE
  PACKAGING
  PORT_FEE
  ICMS_ST
  IPI
  OTHER
}

enum ApportionmentMethod {
  BY_VALUE
  BY_QUANTITY
  BY_WEIGHT
  FIXED
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

model StockEntry {
  id                   String           @id @default(uuid())
  organizationId       String
  entryDate            DateTime         @default(now())
  status               StockEntryStatus @default(DRAFT)
  supplierName         String?
  invoiceNumber        String?
  invoiceFileUrl       String?
  storageFarmId        String?
  storageLocation      String?          // depósito/galpão
  storageSublocation   String?          // prateleira
  notes                String?
  totalMerchandiseCost Decimal          @default(0) @db.Decimal(14, 2)
  totalExpensesCost    Decimal          @default(0) @db.Decimal(14, 2)
  totalCost            Decimal          @default(0) @db.Decimal(14, 2)
  createdBy            String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  cancelledAt          DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storageFarm  Farm?              @relation(fields: [storageFarmId], references: [id], onDelete: SetNull)
  items        StockEntryItem[]
  expenses     StockEntryExpense[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, entryDate])
  @@index([organizationId, supplierName])
  @@map("stock_entries")
}

model StockEntryItem {
  id                  String   @id @default(uuid())
  stockEntryId        String
  productId           String
  quantity            Decimal  @db.Decimal(14, 4) // quantidade na unidade de compra
  unitCost            Decimal  @db.Decimal(14, 4) // custo por unidade de compra
  totalCost           Decimal  @db.Decimal(14, 2) // quantity * unitCost
  batchNumber         String?
  manufacturingDate   DateTime?
  expirationDate      DateTime?
  apportionedExpenses Decimal  @default(0) @db.Decimal(14, 4)
  finalUnitCost       Decimal  @default(0) @db.Decimal(14, 4)
  finalTotalCost      Decimal  @default(0) @db.Decimal(14, 2)
  weightKg            Decimal? @db.Decimal(14, 4)

  // US-097: conversão automática compra → estoque
  purchaseUnitId      String?  // unidade em que foi comprado (ex: tonelada)
  stockQuantity       Decimal? @db.Decimal(14, 4) // quantidade convertida para unidade de estoque
  stockUnitId         String?  // unidade de estoque (ex: kg)
  conversionFactor    Decimal? @db.Decimal(20, 10) // fator usado na conversão

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  stockEntry   StockEntry       @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  product      Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseUnit MeasurementUnit? @relation("EntryItemPurchaseUnit", fields: [purchaseUnitId], references: [id], onDelete: SetNull)
  stockUnit    MeasurementUnit? @relation("EntryItemStockUnit", fields: [stockUnitId], references: [id], onDelete: SetNull)

  @@index([stockEntryId])
  @@index([productId])
  @@map("stock_entry_items")
}

model StockEntryExpense {
  id                  String              @id @default(uuid())
  stockEntryId        String
  expenseType         ExpenseType
  description         String?
  supplierName        String?
  invoiceNumber       String?
  invoiceFileUrl      String?
  amount              Decimal             @db.Decimal(14, 2)
  apportionmentMethod ApportionmentMethod @default(BY_VALUE)
  isRetroactive       Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  stockEntry StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)

  @@index([stockEntryId])
  @@map("stock_entry_expenses")
}

model StockBalance {
  id              String    @id @default(uuid())
  organizationId  String
  productId       String    @unique
  currentQuantity Decimal   @default(0) @db.Decimal(14, 4)
  averageCost     Decimal   @default(0) @db.Decimal(14, 4)
  totalValue      Decimal   @default(0) @db.Decimal(14, 2)
  lastEntryDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([organizationId, productId])
  @@index([organizationId])
  @@map("stock_balances")
}

// ─── EPIC-10 US-091: Saída de Insumos do Estoque ────────────────────

enum StockOutputType {
  CONSUMPTION
  MANUAL_CONSUMPTION
  TRANSFER
  DISPOSAL
}

enum StockOutputStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum DisposalReason {
  EXPIRED
  DAMAGED
  CONTAMINATED
  OTHER
}

model StockOutput {
  id                  String            @id @default(uuid())
  organizationId      String
  outputDate          DateTime          @default(now())
  type                StockOutputType
  status              StockOutputStatus @default(DRAFT)

  // CONSUMPTION / MANUAL_CONSUMPTION
  fieldOperationRef   String?           // referência textual à operação de campo
  fieldPlotId         String?           // talhão destino do consumo

  // TRANSFER
  sourceFarmId        String?
  sourceLocation      String?           // depósito/galpão de origem
  destinationFarmId   String?
  destinationLocation String?           // depósito/galpão de destino

  // DISPOSAL
  disposalReason      DisposalReason?
  disposalJustification String?         // justificativa detalhada
  authorizedBy        String?           // quem autorizou o descarte

  // Common
  responsibleName     String?
  notes               String?
  totalCost           Decimal           @default(0) @db.Decimal(14, 2)
  createdBy           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  cancelledAt         DateTime?

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceFarm      Farm?             @relation("SourceFarmOutputs", fields: [sourceFarmId], references: [id], onDelete: SetNull)
  destinationFarm Farm?             @relation("DestinationFarmOutputs", fields: [destinationFarmId], references: [id], onDelete: SetNull)
  items           StockOutputItem[]
  pesticideApplications  PesticideApplication[]  @relation("PesticideStockOutput")
  fertilizerApplications FertilizerApplication[] @relation("FertilizerStockOutput")
  soilPrepOperations     SoilPrepOperation[]     @relation("SoilPrepStockOutput")
  plantingOperations     PlantingOperation[]     @relation("PlantingStockOutput")
  vaccinations           Vaccination[]
  dewormings             Deworming[]
  treatmentApplications  TreatmentApplication[]

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([organizationId, outputDate])
  @@map("stock_outputs")
}

model StockOutputItem {
  id            String   @id @default(uuid())
  stockOutputId String
  productId     String
  quantity      Decimal  @db.Decimal(14, 4)
  unitCost      Decimal  @db.Decimal(14, 4) // custo médio no momento da saída
  totalCost     Decimal  @db.Decimal(14, 2)
  batchNumber   String?  // lote (FEFO)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stockOutput StockOutput @relation(fields: [stockOutputId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([stockOutputId])
  @@index([productId])
  @@map("stock_output_items")
}

// ─── EPIC-10 US-093: Inventário e Conciliação de Estoque ────────────

enum StockInventoryStatus {
  OPEN
  IN_PROGRESS
  RECONCILED
  CANCELLED
}

enum AdjustmentType {
  INVENTORY_SURPLUS
  INVENTORY_SHORTAGE
}

model StockInventory {
  id               String               @id @default(uuid())
  organizationId   String
  inventoryDate    DateTime             @default(now())
  status           StockInventoryStatus @default(OPEN)
  storageFarmId    String?
  storageLocation  String?              // depósito/galpão
  notes            String?
  reconciledAt     DateTime?
  reconciledBy     String?
  createdBy        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  cancelledAt      DateTime?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storageFarm  Farm?                  @relation(fields: [storageFarmId], references: [id], onDelete: SetNull)
  items        StockInventoryItem[]
  adjustments  StockAdjustment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, inventoryDate])
  @@map("stock_inventories")
}

model StockInventoryItem {
  id               String   @id @default(uuid())
  stockInventoryId String
  productId        String
  batchNumber      String?
  systemQuantity   Decimal  @db.Decimal(14, 4) // saldo no momento da contagem
  countedQuantity  Decimal? @db.Decimal(14, 4) // quantidade contada fisicamente
  variance         Decimal? @db.Decimal(14, 4) // countedQuantity - systemQuantity
  reason           String?  // motivo da divergência
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stockInventory StockInventory @relation(fields: [stockInventoryId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([stockInventoryId, productId, batchNumber])
  @@index([stockInventoryId])
  @@index([productId])
  @@map("stock_inventory_items")
}

// ── Receituário Agronômico (US-094) ──

enum PrescriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model PesticidePrescription {
  id                   String             @id @default(uuid())
  organizationId       String
  farmId               String
  fieldPlotId          String
  sequentialNumber     Int                // CA8: numeração sequencial por fazenda
  issuedAt             DateTime           @default(now())

  // CA2: auto-filled from context
  farmName             String
  fieldPlotName        String
  cultureName          String             // cultura plantada no talhão
  areaHa               Decimal            @db.Decimal(12, 4)
  targetPest           String             // praga/doença alvo
  targetType           PesticideTarget    // PRAGA, DOENCA, PLANTA_DANINHA

  // CA3: dose info
  sprayVolume          Decimal            @db.Decimal(10, 2) // volume de calda L/ha
  numberOfApplications Int                @default(1)
  applicationInterval  Int?               // intervalo entre aplicações (dias)

  // CA4: dados do agrônomo
  agronomistName       String
  agronomistCrea       String
  agronomistSignatureUrl String?          // URL da assinatura digital

  // CA7: vinculação
  pesticideApplicationId String?          // link to pesticide application
  stockOutputId        String?            // link to stock output

  // metadata
  technicalJustification String?
  notes                String?
  status               PrescriptionStatus @default(ACTIVE)
  createdBy            String
  deletedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  farm         Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldPlot    FieldPlot    @relation(fields: [fieldPlotId], references: [id], onDelete: Cascade)
  creator      User         @relation("PrescriptionCreator", fields: [createdBy], references: [id])
  products     PesticidePrescriptionProduct[]

  @@unique([farmId, sequentialNumber])
  @@index([organizationId])
  @@index([farmId])
  @@index([fieldPlotId])
  @@map("pesticide_prescriptions")
}

model PesticidePrescriptionProduct {
  id                   String  @id @default(uuid())
  prescriptionId       String
  productId            String?
  productName          String
  activeIngredient     String
  dose                 Decimal @db.Decimal(10, 4)
  doseUnit             DoseUnit @default(L_HA)

  // CA5: carência e segurança
  withdrawalPeriodDays Int?
  safetyIntervalDays   Int?    // intervalo de segurança (reentrada)

  // product details (snapshot)
  toxicityClass        String?
  mapaRegistration     String?
  environmentalClass   String?

  prescription PesticidePrescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  product      Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([prescriptionId])
  @@index([productId])
  @@map("pesticide_prescription_products")
}

model StockAdjustment {
  id               String         @id @default(uuid())
  organizationId   String
  stockInventoryId String
  productId        String
  adjustmentType   AdjustmentType
  previousQuantity Decimal        @db.Decimal(14, 4)
  newQuantity      Decimal        @db.Decimal(14, 4)
  adjustmentQty    Decimal        @db.Decimal(14, 4) // diferença absoluta
  reason           String
  createdBy        String?
  createdAt        DateTime       @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockInventory StockInventory @relation(fields: [stockInventoryId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([stockInventoryId])
  @@index([productId])
  @@map("stock_adjustments")
}

// ─── Disease Catalog (EPIC-11 / US-103) ─────────────────────────────

enum DiseaseCategory {
  INFECTIOUS
  METABOLIC
  REPRODUCTIVE
  LOCOMOTOR
  PARASITIC
  NUTRITIONAL
  OTHER
}

enum DiseaseSeverity {
  MILD
  MODERATE
  SEVERE
}

enum AffectedSystem {
  DIGESTIVE
  REPRODUCTIVE
  LOCOMOTOR
  MAMMARY
  RESPIRATORY
  SYSTEMIC
}

model Disease {
  id                   String           @id @default(uuid())
  organizationId       String           @map("organization_id")
  name                 String
  scientificName       String?          @map("scientific_name")
  code                 String?
  category             DiseaseCategory
  severity             DiseaseSeverity?
  affectedSystem       AffectedSystem?  @map("affected_system")
  symptoms             String?
  quarantineDays       Int?             @map("quarantine_days")
  isNotifiable         Boolean          @default(false) @map("is_notifiable")
  photoUrl             String?          @map("photo_url")
  notes                String?
  deletedAt            DateTime?        @map("deleted_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  treatmentProtocolDiseases TreatmentProtocolDisease[]
  therapeuticTreatments     TherapeuticTreatment[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([category])
  @@map("diseases")
}

// ─── EPIC-11 US-104: Protocolos de Tratamento ──────────────────────

enum AdministrationRoute {
  IM
  SC
  IV
  ORAL
  INTRAMMARY
  TOPICAL
}

enum DosageUnit {
  MG_KG
  ML_ANIMAL
  FIXED_DOSE
}

enum ProtocolStatus {
  ACTIVE
  INACTIVE
}

model TreatmentProtocol {
  id                 String           @id @default(uuid())
  organizationId     String           @map("organization_id")
  name               String
  description        String?
  notes              String?
  severity           DiseaseSeverity?
  authorName         String           @map("author_name")
  status             ProtocolStatus   @default(ACTIVE)
  version            Int              @default(1)
  originalId         String?          @map("original_id")
  withdrawalMeatDays Int?             @map("withdrawal_meat_days")
  withdrawalMilkDays Int?             @map("withdrawal_milk_days")
  estimatedCostCents Int?             @map("estimated_cost_cents")
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id])
  original     TreatmentProtocol?     @relation("ProtocolVersions", fields: [originalId], references: [id])
  versions     TreatmentProtocol[]    @relation("ProtocolVersions")
  diseases     TreatmentProtocolDisease[]
  steps        TreatmentProtocolStep[]
  therapeuticTreatments TherapeuticTreatment[]

  @@unique([name, organizationId, version])
  @@index([organizationId])
  @@index([originalId])
  @@index([status])
  @@map("treatment_protocols")
}

model TreatmentProtocolDisease {
  id         String            @id @default(uuid())
  protocolId String            @map("protocol_id")
  diseaseId  String            @map("disease_id")

  protocol   TreatmentProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  disease    Disease           @relation(fields: [diseaseId], references: [id])

  @@unique([protocolId, diseaseId])
  @@index([protocolId])
  @@index([diseaseId])
  @@map("treatment_protocol_diseases")
}

model TreatmentProtocolStep {
  id                  String              @id @default(uuid())
  protocolId          String              @map("protocol_id")
  order               Int
  productId           String?             @map("product_id")
  productName         String              @map("product_name")
  dosage              Float
  dosageUnit          DosageUnit          @map("dosage_unit")
  administrationRoute AdministrationRoute @map("administration_route")
  frequencyPerDay     Int                 @default(1) @map("frequency_per_day")
  startDay            Int                 @default(1) @map("start_day")
  durationDays        Int                 @map("duration_days")
  withdrawalMeatDays  Int?                @map("withdrawal_meat_days")
  withdrawalMilkDays  Int?                @map("withdrawal_milk_days")
  notes               String?

  protocol TreatmentProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  product  Product?          @relation(fields: [productId], references: [id])

  @@index([protocolId])
  @@map("treatment_protocol_steps")
}

// ─── EPIC-11 US-100: Protocolos Sanitários ─────────────────────────

enum SanitaryProcedureType {
  VACCINATION
  DEWORMING
  EXAM
  MEDICATION
  OTHER
}

enum SanitaryTriggerType {
  AGE
  EVENT
  CALENDAR
}

enum SanitaryEventTrigger {
  BIRTH
  WEANING
  REPRODUCTIVE_RELEASE
  PRE_IATF
  DRYING
  PRE_PARTUM
  POST_PARTUM
  TRANSITION
  FARM_ENTRY
  FARM_EXIT
}

enum CalendarFrequency {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
}

enum SanitaryProtocolStatus {
  ACTIVE
  INACTIVE
}

model SanitaryProtocol {
  id             String                  @id @default(uuid())
  organizationId String                  @map("organization_id")
  name           String
  description    String?
  authorName     String                  @map("author_name")
  status         SanitaryProtocolStatus  @default(ACTIVE)
  version        Int                     @default(1)
  originalId     String?                 @map("original_id")
  isObligatory   Boolean                 @default(false) @map("is_obligatory")
  targetCategories AnimalCategory[]      @map("target_categories")
  deletedAt      DateTime?               @map("deleted_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  organization Organization              @relation(fields: [organizationId], references: [id])
  original     SanitaryProtocol?          @relation("SanitaryProtocolVersions", fields: [originalId], references: [id])
  versions     SanitaryProtocol[]         @relation("SanitaryProtocolVersions")
  items        SanitaryProtocolItem[]

  @@unique([name, organizationId, version])
  @@index([organizationId])
  @@index([originalId])
  @@index([status])
  @@map("sanitary_protocols")
}

model SanitaryProtocolItem {
  id                  String                @id @default(uuid())
  protocolId          String                @map("protocol_id")
  order               Int
  procedureType       SanitaryProcedureType @map("procedure_type")
  productId           String?               @map("product_id")
  productName         String                @map("product_name")
  dosage              Float?
  dosageUnit          DosageUnit?           @map("dosage_unit")
  administrationRoute AdministrationRoute?  @map("administration_route")
  triggerType         SanitaryTriggerType   @map("trigger_type")
  triggerAgeDays      Int?                  @map("trigger_age_days")
  triggerAgeMaxDays   Int?                  @map("trigger_age_max_days")
  triggerEvent        SanitaryEventTrigger? @map("trigger_event")
  triggerEventOffsetDays Int?               @map("trigger_event_offset_days")
  calendarFrequency   CalendarFrequency?    @map("calendar_frequency")
  calendarMonths      Int[]                 @map("calendar_months")
  isReinforcement     Boolean               @default(false) @map("is_reinforcement")
  reinforcementIntervalDays Int?            @map("reinforcement_interval_days")
  reinforcementDoseNumber   Int?            @map("reinforcement_dose_number")
  withdrawalMeatDays  Int?                  @map("withdrawal_meat_days")
  withdrawalMilkDays  Int?                  @map("withdrawal_milk_days")
  notes               String?

  protocol SanitaryProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  product  Product?         @relation(fields: [productId], references: [id])

  vaccinations Vaccination[]
  dewormings   Deworming[]

  @@index([protocolId])
  @@map("sanitary_protocol_items")
}

// ─── EPIC-11 US-101: Vacinação ──────────────────────────────────────

