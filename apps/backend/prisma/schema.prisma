// ─── EPIC-12 US-110: Detecção de Cio ────────────────────────────────

enum HeatDetectionMethod {
  VISUAL
  MARKER_PAINT
  PEDOMETER
  TEASER
}

enum HeatStatus {
  AWAITING_AI
  AI_DONE
  NOT_INSEMINATED
}

model HeatRecord {
  id                    String              @id @default(uuid())
  organizationId        String
  farmId                String
  animalId              String
  heatDate              DateTime            @db.Date
  heatTime              String?             // "08:30" or period
  heatPeriod            String?             // MORNING, AFTERNOON, NIGHT
  intensity             HeatIntensity
  signs                 Json                // string array: ["mount_accepted", "mucus", ...]
  detectionMethod       HeatDetectionMethod
  status                HeatStatus          @default(AWAITING_AI)
  // AI alert (CA3)
  recommendedAiTime     DateTime?
  recommendedBullId     String?
  // Cyclicity (CA7)
  cyclicityStatus       String?             // CYCLING, ANESTRUS, FOLLICULAR_CYST, etc.
  // Inter-heat (CA4)
  previousHeatDate      DateTime?           @db.Date
  interHeatDays         Int?
  isIntervalIrregular   Boolean             @default(false)
  inseminationId        String?             // link to future insemination record
  notInseminatedReason  String?
  notes                 String?
  recordedBy            String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  farm          Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal        Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  recorder      User         @relation("HeatRecorder", fields: [recordedBy], references: [id])

  @@index([organizationId])
  @@index([farmId])
  @@index([animalId])
  @@index([heatDate])
  @@index([status])
  @@map("heat_records")
}

// ─── EPIC-12 US-111: Plano de Acasalamento ──────────────────────────

enum MatingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MatingPairStatus {
  PLANNED
  EXECUTED
  CONFIRMED_PREGNANT
  EMPTY
  CANCELLED
}

model MatingPlan {
  id                String           @id @default(uuid())
