// ─── EPIC-12 US-110: Detecção de Cio ────────────────────────────────

enum HeatDetectionMethod {
  VISUAL
  MARKER_PAINT
  PEDOMETER
  TEASER
}

enum HeatStatus {
  AWAITING_AI
  AI_DONE
  NOT_INSEMINATED
}

model HeatRecord {
  id                    String              @id @default(uuid())
  organizationId        String
  farmId                String
  animalId              String
  heatDate              DateTime            @db.Date
  heatTime              String?             // "08:30" or period
  heatPeriod            String?             // MORNING, AFTERNOON, NIGHT
  intensity             HeatIntensity
  signs                 Json                // string array: ["mount_accepted", "mucus", ...]
  detectionMethod       HeatDetectionMethod
  status                HeatStatus          @default(AWAITING_AI)
  // AI alert (CA3)
  recommendedAiTime     DateTime?
  recommendedBullId     String?
  // Cyclicity (CA7)
