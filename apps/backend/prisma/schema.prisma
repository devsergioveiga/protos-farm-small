// ─── EPIC Financial Foundation — Bank Accounts ────────────────────────────────

enum BankAccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  RURAL_CREDIT
}

model BankAccount {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  type           BankAccountType
  bankCode       String
  agency         String
  agencyDigit    String?
  accountNumber  String
  accountDigit   String?
  producerId     String?
  notes          String?
  isActive       Boolean         @default(true)
  // CNAB convenience fields
  convenioCode   String?
  carteira       String?
  variacao       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  producer       Producer?             @relation(fields: [producerId], references: [id], onDelete: SetNull)
  farms          BankAccountFarm[]
  balance        BankAccountBalance?
  transactions   FinancialTransaction[]
  payables       Payable[]
  receivables    Receivable[]
  transfersFrom  AccountTransfer[]     @relation("TransferFrom")
  transfersTo    AccountTransfer[]     @relation("TransferTo")
  creditCards    CreditCard[]          @relation("CardDebitAccount")
  checks         Check[]

  @@index([organizationId])
  @@index([organizationId, type])
  @@map("bank_accounts")
}

model BankAccountFarm {
  id            String @id @default(uuid())
  bankAccountId String
  farmId        String

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  farm        Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([bankAccountId, farmId])
  @@map("bank_account_farms")
}

model BankAccountBalance {
  id             String   @id @default(uuid())
  bankAccountId  String   @unique
  organizationId String
  initialBalance Decimal  @default(0) @db.Decimal(15, 2)
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt      DateTime @updatedAt

  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("bank_account_balances")
}

model FinancialTransaction {
  id              String    @id @default(uuid())
  organizationId  String
  bankAccountId   String
  type            String
  amount          Decimal   @db.Decimal(15, 2)
  description     String
  referenceType   String?
  referenceId     String?
  transactionDate DateTime
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id])

  @@index([organizationId, bankAccountId])
  @@index([organizationId, bankAccountId, transactionDate])
  @@map("financial_transactions")
}

// ─── EPIC AP/AR — Contas a Pagar / Contas a Receber ──────────────────────────

enum PayableStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum ReceivableStatus {
  PENDING
  RECEIVED
  PARTIAL
  OVERDUE
  CANCELLED
  RENEGOTIATED
}

enum RecurrenceFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PayableCategory {
  INPUTS
  MAINTENANCE
  PAYROLL
  RENT
  SERVICES
  TAXES
  FINANCING
  OTHER
  CARTAO_CREDITO
}

// ─── Phase 4: Payment Instruments Enums ──────────────────────────────

enum TransferType {
  INTERNA
  TED
  APLICACAO
  RESGATE
}

enum CardBrand {
  VISA
  MASTERCARD
  ELO
  AMEX
  HIPERCARD
  OTHER
}

enum BillStatus {
  OPEN
  CLOSED
}

enum CheckType {
  EMITIDO
  RECEBIDO
}

enum CheckStatus {
  EMITIDO
  A_COMPENSAR
  COMPENSADO
  DEVOLVIDO
  CANCELADO
}

enum ReceivableCategory {
  GRAIN_SALE
  CATTLE_SALE
  MILK_SALE
  LEASE
  SERVICES
  OTHER
}

enum CostCenterAllocMode {
  PERCENTAGE
  FIXED_VALUE
}

model Payable {
  id                  String              @id @default(uuid())
  organizationId      String
  farmId              String
  producerId          String?
  supplierName        String
  category            PayableCategory
  description         String
  totalAmount         Decimal             @db.Decimal(15, 2)
  dueDate             DateTime
  status              PayableStatus       @default(PENDING)
  documentNumber      String?
  originType          String?
  originId            String?
  recurrenceFrequency RecurrenceFrequency?
  recurrenceEndDate   DateTime?
  recurrenceParentId  String?
  installmentCount    Int                 @default(1)
  paidAt              DateTime?
  amountPaid          Decimal?            @db.Decimal(15, 2)
  bankAccountId       String?
  interestAmount      Decimal?            @db.Decimal(15, 2)
  fineAmount          Decimal?            @db.Decimal(15, 2)
  discountAmount      Decimal?            @db.Decimal(15, 2)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  farm               Farm                   @relation(fields: [farmId], references: [id], onDelete: Restrict)
  producer           Producer?              @relation(fields: [producerId], references: [id], onDelete: SetNull)
  bankAccount        BankAccount?           @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  installments       PayableInstallment[]
  costCenterItems    PayableCostCenterItem[]
  recurrenceChildren Payable[]              @relation("PayableRecurrence")
  recurrenceParent   Payable?               @relation("PayableRecurrence", fields: [recurrenceParentId], references: [id])
  creditCardBill     CreditCardBill?

  @@index([organizationId, status, dueDate])
  @@index([organizationId, farmId])
  @@map("payables")
}

model PayableInstallment {
  id         String        @id @default(uuid())
  payableId  String
  number     Int
  amount     Decimal       @db.Decimal(15, 2)
  dueDate    DateTime
  status     PayableStatus @default(PENDING)
  paidAt     DateTime?
  amountPaid Decimal?      @db.Decimal(15, 2)

  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@index([payableId])
  @@map("payable_installments")
}

model PayableCostCenterItem {
  id           String              @id @default(uuid())
  payableId    String
  costCenterId String
  farmId       String
  allocMode    CostCenterAllocMode
  percentage   Decimal?            @db.Decimal(5, 2)
  fixedAmount  Decimal?            @db.Decimal(15, 2)

  payable    Payable    @relation(fields: [payableId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  farm       Farm       @relation(fields: [farmId], references: [id], onDelete: Restrict)

  @@map("payable_cost_center_items")
}

model Receivable {
  id                  String             @id @default(uuid())
  organizationId      String
  farmId              String
  producerId          String?
  clientName          String
  category            ReceivableCategory
  description         String
  totalAmount         Decimal            @db.Decimal(15, 2)
  dueDate             DateTime
  status              ReceivableStatus   @default(PENDING)
  documentNumber      String?
  nfeKey              String?
  funruralRate        Decimal?           @db.Decimal(5, 4)
  funruralAmount      Decimal?           @db.Decimal(15, 2)
  originType          String?
  originId            String?
  recurrenceFrequency RecurrenceFrequency?
  recurrenceEndDate   DateTime?
  recurrenceParentId  String?
  installmentCount    Int                @default(1)
  receivedAt          DateTime?
  amountReceived      Decimal?           @db.Decimal(15, 2)
  bankAccountId       String?
  interestAmount      Decimal?           @db.Decimal(15, 2)
  fineAmount          Decimal?           @db.Decimal(15, 2)
  discountAmount      Decimal?           @db.Decimal(15, 2)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  farm                 Farm                      @relation(fields: [farmId], references: [id], onDelete: Restrict)
  producer             Producer?                 @relation(fields: [producerId], references: [id], onDelete: SetNull)
  bankAccount          BankAccount?              @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  installments         ReceivableInstallment[]
  costCenterItems      ReceivableCostCenterItem[]
  recurrenceChildren   Receivable[]              @relation("ReceivableRecurrence")
  recurrenceParent     Receivable?               @relation("ReceivableRecurrence", fields: [recurrenceParentId], references: [id])

  @@index([organizationId, status, dueDate])
  @@index([organizationId, farmId])
  @@map("receivables")
}

model ReceivableInstallment {
  id             String           @id @default(uuid())
  receivableId   String
  number         Int
  amount         Decimal          @db.Decimal(15, 2)
  dueDate        DateTime
  status         ReceivableStatus @default(PENDING)
  receivedAt     DateTime?
  amountReceived Decimal?         @db.Decimal(15, 2)

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@index([receivableId])
  @@map("receivable_installments")
}

model ReceivableCostCenterItem {
  id           String              @id @default(uuid())
  receivableId String
  costCenterId String
  farmId       String
  allocMode    CostCenterAllocMode
  percentage   Decimal?            @db.Decimal(5, 2)
  fixedAmount  Decimal?            @db.Decimal(15, 2)

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  farm       Farm       @relation(fields: [farmId], references: [id], onDelete: Restrict)

  @@map("receivable_cost_center_items")
}

// ─── Phase 4: Payment Instruments Models ─────────────────────────────

model AccountTransfer {
  id             String       @id @default(uuid())
  organizationId String
  fromAccountId  String
  toAccountId    String
  type           TransferType
  amount         Decimal      @db.Decimal(15, 2)
  feeAmount      Decimal?     @db.Decimal(15, 2)
  description    String
  transferDate   DateTime
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  fromAccount  BankAccount  @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount    BankAccount  @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([organizationId, transferDate])
  @@map("account_transfers")
}

model CreditCard {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  brand          CardBrand
  lastFourDigits String?
  creditLimit    Decimal   @db.Decimal(15, 2)
  closingDay     Int
  dueDay         Int
  debitAccountId String
  farmId         String
  holder         String
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  debitAccount BankAccount         @relation("CardDebitAccount", fields: [debitAccountId], references: [id])
  farm         Farm                @relation(fields: [farmId], references: [id])
  expenses     CreditCardExpense[]
  bills        CreditCardBill[]

  @@index([organizationId])
  @@map("credit_cards")
}

model CreditCardBill {
  id             String     @id @default(uuid())
  creditCardId   String
  organizationId String
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  totalAmount    Decimal    @default(0) @db.Decimal(15, 2)
  status         BillStatus @default(OPEN)
  payableId      String?    @unique
  closedAt       DateTime?
  createdAt      DateTime   @default(now())

  creditCard   CreditCard          @relation(fields: [creditCardId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])
  expenses     CreditCardExpense[]
  payable      Payable?            @relation(fields: [payableId], references: [id])

  @@index([creditCardId, periodStart])
  @@map("credit_card_bills")
}

model CreditCardExpense {
  id                String   @id @default(uuid())
  organizationId    String
  creditCardId      String
  billId            String?
  description       String
  amount            Decimal  @db.Decimal(15, 2)
  expenseDate       DateTime
  installmentNumber Int      @default(1)
  totalInstallments Int      @default(1)
  category          String?
  notes             String?
  createdAt         DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id])
  creditCard   CreditCard      @relation(fields: [creditCardId], references: [id])
  bill         CreditCardBill? @relation(fields: [billId], references: [id])

  @@index([creditCardId, expenseDate])
  @@map("credit_card_expenses")
}

model Check {
  id                       String      @id @default(uuid())
  organizationId           String
  type                     CheckType
  status                   CheckStatus @default(EMITIDO)
  checkNumber              String
  amount                   Decimal     @db.Decimal(15, 2)
  bankAccountId            String
  issueDate                DateTime
  deliveryDate             DateTime?
  expectedCompensationDate DateTime?
  compensationDate         DateTime?
  payeeName                String
  description              String?
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, expectedCompensationDate])
  @@map("checks")
}
