  organization Organization @relation(fields: [organizationId], references: [id])
  position     Position     @relation(fields: [positionId], references: [id])
  epiProduct   EpiProduct   @relation(fields: [epiProductId], references: [id])

  @@unique([positionId, epiProductId])
  @@map("position_epi_requirements")
}

model TrainingType {
  id                     String    @id @default(uuid())
  organizationId         String?
  name                   String
  description            String?
  minHours               Int
  defaultValidityMonths  Int
  nrReference            String?
  isSystem               Boolean   @default(false)
  isGlobal               Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  trainingRecords      TrainingRecord[]
  positionRequirements PositionTrainingRequirement[]

  @@unique([organizationId, name])
  @@map("training_types")
}

model TrainingRecord {
  id                      String         @id @default(uuid())
  organizationId          String
  farmId                  String?
  trainingTypeId          String
  date                    DateTime
  instructorName          String
  instructorType          InstructorType
  instructorRegistration  String?
  effectiveHours          Decimal        @db.Decimal(5, 1)
  location                String?
  observations            String?
  certificateUrl          String?
  attendanceListUrl       String?
  createdBy               String
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  organization     Organization             @relation(fields: [organizationId], references: [id])
  trainingType     TrainingType             @relation(fields: [trainingTypeId], references: [id])
  employeeRecords  EmployeeTrainingRecord[]

  @@index([organizationId])
  @@map("training_records")
}

model EmployeeTrainingRecord {
  id               String   @id @default(uuid())
  trainingRecordId String
  employeeId       String
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  trainingRecord TrainingRecord @relation(fields: [trainingRecordId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])

  @@unique([trainingRecordId, employeeId])
  @@index([employeeId])
  @@map("employee_training_records")
}

model PositionTrainingRequirement {
  id             String   @id @default(uuid())
  organizationId String
  positionId     String
  trainingTypeId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  position     Position     @relation(fields: [positionId], references: [id])
  trainingType TrainingType @relation(fields: [trainingTypeId], references: [id])

  @@unique([positionId, trainingTypeId])
  @@map("position_training_requirements")
}

model MedicalExam {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  farmId         String?
  type           AsoType
  date           DateTime
  doctorName     String
  doctorCrm      String
  result         AsoResult
  restrictions   String?
  nextExamDate   DateTime?
  documentUrl    String?
  observations   String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("medical_exams")
}

// ── Phase 31: Obrigações Acessórias e eSocial ──

enum TaxGuideType {
  FGTS
  INSS
  IRRF
  FUNRURAL
}

enum TaxGuideStatus {
  PENDING
  GENERATED
  PAID
  OVERDUE
}

enum EsocialGroup {
  TABELA
  NAO_PERIODICO
  PERIODICO
  SST
}

enum EsocialStatus {
  PENDENTE
  EXPORTADO
  ACEITO
  REJEITADO
}

enum FunruralBasis {
  GROSS_REVENUE
  PAYROLL
}

// ── Phase 35 Plan 01: Chart of Accounts & Fiscal Periods ──

enum AccountType {
  ATIVO
  PASSIVO
  PL
  RECEITA
  DESPESA
}

enum AccountNature {
  DEVEDORA
  CREDORA
}

enum PeriodStatus {
  OPEN
  CLOSED
  BLOCKED
}

model TaxGuide {
  id             String         @id @default(uuid())
  organizationId String
  guideType      TaxGuideType
  referenceMonth DateTime       @db.Date
  dueDate        DateTime       @db.Date
  totalAmount    Decimal        @db.Decimal(14, 2)
  status         TaxGuideStatus @default(PENDING)
  fileKey        String?
  payrollRunId   String?
  generatedBy    String?
  generatedAt    DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, guideType, referenceMonth])
  @@index([organizationId, status])
  @@map("tax_guides")
}

model EsocialEvent {
  id              String        @id @default(uuid())
  organizationId  String
  eventType       String
  eventGroup      EsocialGroup
  referenceMonth  DateTime?     @db.Date
  sourceType      String
  sourceId        String
  status          EsocialStatus @default(PENDENTE)
  version         Int           @default(1)
  xmlContent      String?       @db.Text
  rejectionReason String?
  exportedAt      DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, eventGroup, status])
  @@index([organizationId, referenceMonth])
  @@index([sourceType, sourceId])
  @@map("esocial_events")
}

model IncomeStatement {
  id                 String   @id @default(uuid())
  organizationId     String
  employeeId         String
  yearBase           Int
  totalTaxable       Decimal  @db.Decimal(14, 2)
  totalInss          Decimal  @db.Decimal(14, 2)
  totalIrrf          Decimal  @db.Decimal(14, 2)
  totalExempt        Decimal  @db.Decimal(14, 2)
  dependentDeduction Decimal  @db.Decimal(14, 2) @default(0)
  pdfKey             String?
  sentAt             DateTime?
  sentTo             String?
  createdBy          String
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@unique([organizationId, employeeId, yearBase])
  @@index([organizationId, yearBase])
  @@map("income_statements")
}

// ── Phase 32 Plan 02: Accounting Entries (INTEGR-02) ──

// ── Phase 35 Plan 01: Chart of Accounts, Fiscal Years, Accounting Periods, Account Balances ──

model ChartOfAccount {
  id               String        @id @default(uuid())
  organizationId   String
  parentId         String?
  code             String
  name             String
  accountType      AccountType
  nature           AccountNature
  isSynthetic      Boolean       @default(false)
  allowManualEntry Boolean       @default(true)
  isActive         Boolean       @default(true)
  isFairValueAdj   Boolean       @default(false)
  spedRefCode      String?
  level            Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  parent            ChartOfAccount?    @relation("CoaTree", fields: [parentId], references: [id])
  children          ChartOfAccount[]   @relation("CoaTree")
  accountBalances   AccountBalance[]
  journalEntryLines JournalEntryLine[]
  accountingRuleLines AccountingRuleLine[]

  @@unique([organizationId, code])
  @@index([organizationId, accountType])
  @@index([parentId])
  @@map("chart_of_accounts")
}

model FiscalYear {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  startDate      DateTime  @db.Date
  endDate        DateTime  @db.Date
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  accountingPeriods AccountingPeriod[]
  accountBalances   AccountBalance[]

  @@unique([organizationId, startDate])
  @@index([organizationId])
  @@map("fiscal_years")
}

model AccountingPeriod {
  id             String       @id @default(uuid())
  organizationId String
  fiscalYearId   String
  month          Int
  year           Int
  status         PeriodStatus @default(OPEN)
  openedAt       DateTime     @default(now())
  closedAt       DateTime?
  closedBy       String?
  reopenedAt     DateTime?
  reopenedBy     String?
  reopenReason   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id])
  fiscalYear      FiscalYear     @relation(fields: [fiscalYearId], references: [id])
  closedByUser    User?          @relation("PeriodClose", fields: [closedBy], references: [id])
  reopenedByUser  User?          @relation("PeriodReopen", fields: [reopenedBy], references: [id])
  journalEntries  JournalEntry[]
  monthlyClosings MonthlyClosing[]

  @@unique([organizationId, fiscalYearId, month, year])
  @@index([organizationId, status])
  @@map("accounting_periods")
}

model AccountBalance {
  id              String   @id @default(uuid())
  organizationId  String
  accountId       String
  fiscalYearId    String
  month           Int
  openingBalance  Decimal  @default(0) @db.Decimal(14, 2)
  debitTotal      Decimal  @default(0) @db.Decimal(14, 2)
  creditTotal     Decimal  @default(0) @db.Decimal(14, 2)
  closingBalance  Decimal  @default(0) @db.Decimal(14, 2)
  costCenterId    String?
  updatedAt       DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  account      ChartOfAccount  @relation(fields: [accountId], references: [id])
  fiscalYear   FiscalYear      @relation(fields: [fiscalYearId], references: [id])
  costCenter   CostCenter?     @relation(fields: [costCenterId], references: [id])

  @@unique([organizationId, accountId, fiscalYearId, month])
  @@index([organizationId, fiscalYearId])
  @@map("account_balances")
}

// ─── Monthly Closing (6-step checklist + period lock) ─────────────────

enum MonthlyClosingStatus {
  IN_PROGRESS
  COMPLETED
  REOPENED

  @@map("monthly_closing_status")
}

model MonthlyClosing {
  id             String               @id @default(uuid())
  organizationId String
  periodId       String
  status         MonthlyClosingStatus @default(IN_PROGRESS)
  stepResults    Json?
  completedAt    DateTime?
  completedBy    String?
  reopenedAt     DateTime?
  reopenedBy     String?
  reopenReason   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  period       AccountingPeriod @relation(fields: [periodId], references: [id])

  @@index([organizationId, periodId])
  @@map("monthly_closings")
}

// ─── Journal Entries (double-entry bookkeeping engine) ────────────────

enum JournalEntryType {
  MANUAL
  OPENING_BALANCE
  REVERSAL
  TEMPLATE_INSTANCE
  AUTOMATIC
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum LedgerSide {
  DEBIT
  CREDIT
}

model JournalEntry {
  id             String             @id @default(uuid())
  organizationId String
  entryNumber    Int                @default(0)
  entryDate      DateTime           @db.Date
  periodId       String
  description    String             @db.VarChar(500)
  entryType      JournalEntryType   @default(MANUAL)
  status         JournalEntryStatus @default(DRAFT)
  reversedById   String?            @unique
  reversalOf     String?            @unique
  reversalReason String?            @db.VarChar(500)
  templateName   String?
  costCenterId   String?
  createdBy      String
  postedAt       DateTime?
  sourceType     AutoPostingSourceType?
  sourceId       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id])
  period          AccountingPeriod      @relation(fields: [periodId], references: [id])
  lines           JournalEntryLine[]
  reversedByEntry JournalEntry?         @relation("JournalReversal", fields: [reversedById], references: [id])
  reversalOfEntry JournalEntry?         @relation("JournalReversal")
  costCenter      CostCenter?           @relation("JournalEntryCostCenter", fields: [costCenterId], references: [id])
  createdByUser   User                  @relation("JournalEntryCreator", fields: [createdBy], references: [id])
  pendingPosting  PendingJournalPosting?

  @@unique([organizationId, entryNumber])
  @@unique([sourceType, sourceId])
  @@index([organizationId, periodId])
  @@index([organizationId, status])
  @@index([organizationId, entryDate])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  side           LedgerSide
  amount         Decimal      @db.Decimal(14, 2)
  description    String?      @db.VarChar(300)
  costCenterId   String?
  lineOrder      Int

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?    @relation("JournalEntryLineCostCenter", fields: [costCenterId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ── Phase 37 Plan 01: Auto-Posting Engine ──

enum AutoPostingSourceType {
  PAYROLL_RUN_CLOSE
  PAYROLL_PROVISION_VACATION
  PAYROLL_PROVISION_THIRTEENTH
  PAYABLE_SETTLEMENT
  RECEIVABLE_SETTLEMENT
  DEPRECIATION_RUN
  STOCK_ENTRY
  STOCK_OUTPUT_CONSUMPTION
  STOCK_OUTPUT_TRANSFER
  STOCK_OUTPUT_DISPOSAL
  PAYABLE_REVERSAL
  RECEIVABLE_REVERSAL
}

enum PendingPostingStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

model AccountingRule {
  id                String                @id @default(uuid())
  organizationId    String
  sourceType        AutoPostingSourceType
  isActive          Boolean               @default(true)
  historyTemplate   String                @db.VarChar(500)
  requireCostCenter Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  organization    Organization            @relation(fields: [organizationId], references: [id])
  lines           AccountingRuleLine[]
  pendingPostings PendingJournalPosting[]

  @@unique([organizationId, sourceType])
  @@index([organizationId])
  @@map("accounting_rules")
}

model AccountingRuleLine {
  id          String         @id @default(uuid())
  ruleId      String
  lineOrder   Int
  side        LedgerSide
  accountId   String
  description String?        @db.VarChar(300)

  rule    AccountingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([ruleId])
  @@map("accounting_rule_lines")
}

model PendingJournalPosting {
  id               String                @id @default(uuid())
  organizationId   String
  sourceType       AutoPostingSourceType
  sourceId         String
  accountingRuleId String?
  status           PendingPostingStatus  @default(PENDING)
  journalEntryId   String?               @unique
  errorMessage     String?               @db.VarChar(1000)
  metadata         Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  processedAt      DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  accountingRule AccountingRule? @relation(fields: [accountingRuleId], references: [id])
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id])

  @@unique([sourceType, sourceId])
  @@index([organizationId, status])
  @@map("pending_journal_postings")
}
