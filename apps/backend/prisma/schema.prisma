model ProducerRegistrationLink {
  id                 String   @id @default(uuid())
  farmLinkId         String
  farmRegistrationId String
  createdAt          DateTime @default(now())

  farmLink         ProducerFarmLink @relation(fields: [farmLinkId], references: [id], onDelete: Cascade)
  farmRegistration FarmRegistration  @relation(fields: [farmRegistrationId], references: [id], onDelete: Cascade)

  @@unique([farmLinkId, farmRegistrationId])
  @@index([farmLinkId])
  @@index([farmRegistrationId])
  @@map("producer_registration_links")
}

model ProducerDocument {
  id         String   @id @default(uuid())
  producerId String
  type       String
  filename   String
  url        String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  producer Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@index([producerId])
  @@map("producer_documents")
}

// ─── Field Plots ────────────────────────────────────────────────────

model FieldPlot {
  id              String    @id @default(uuid())
  farmId          String
  registrationId  String?
  ruralPropertyId String?
  name            String
  code            String?
  soilType        SoilType?
  currentCrop     String?
  previousCrop    String?
  notes           String?
  boundary        Unsupported("geometry(Polygon, 4326)")
  boundaryAreaHa  Decimal   @db.Decimal(12, 4)
  status          String    @default("ACTIVE")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm              Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  registration      FarmRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  ruralProperty     RuralProperty?    @relation(fields: [ruralPropertyId], references: [id], onDelete: SetNull)
  boundaryVersions  FieldPlotBoundaryVersion[]
  cropSeasons            PlotCropSeason[]
  soilAnalyses           PlotSoilAnalysis[]
  pesticideApplications  PesticideApplication[]
  fertilizerApplications FertilizerApplication[]
  culturalOperations     CulturalOperation[]
  soilPrepOperations     SoilPrepOperation[]
  teamOperations         TeamOperation[]
  monitoringPoints       MonitoringPoint[]
  monitoringRecords      MonitoringRecord[]
  phenologicalRecords    PlotPhenologicalRecord[]
  plantingOperations     PlantingOperation[]
  grainHarvests          GrainHarvest[]
  coffeeHarvests         CoffeeHarvest[]
  orangeHarvests             OrangeHarvest[]
  pesticidePrescriptions     PesticidePrescription[]

  @@index([farmId])
  @@index([registrationId])
  @@index([ruralPropertyId])
  @@map("field_plots")
}

model FieldPlotBoundaryVersion {
  id              String    @id @default(uuid())
  plotId          String
  farmId          String
  boundary        Unsupported("geometry(Polygon, 4326)")
  boundaryAreaHa  Decimal   @db.Decimal(12, 4)
  editedBy        String
  editedAt        DateTime  @default(now())
  editSource      String    @default("file_upload")
  version         Int       @default(1)

  plot     FieldPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)
  farm     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  editor   User      @relation(fields: [editedBy], references: [id])

  @@index([plotId])
  @@index([farmId])
  @@map("field_plot_boundary_versions")
}

// ─── Plot Usage History ────────────────────────────────────────────

model PlotCropSeason {
  id                String     @id @default(uuid())
  plotId            String
  farmId            String
  cultivarId        String?
  seasonType        SeasonType
  seasonYear        String
  crop              String
  varietyName       String?
  startDate         DateTime?  @db.Date
  endDate           DateTime?  @db.Date
  plantedAreaHa     Decimal?   @db.Decimal(12, 4)
  productivityKgHa  Decimal?   @db.Decimal(12, 2)
  totalProductionKg Decimal?   @db.Decimal(14, 2)
  operations        Json?      @default("[]")
  notes             String?
  createdBy         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  plot     FieldPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)
  farm     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  creator  User      @relation(fields: [createdBy], references: [id])
  cultivar Cultivar? @relation(fields: [cultivarId], references: [id], onDelete: SetNull)

  @@index([plotId])
  @@index([farmId])
  @@index([cultivarId])
  @@index([startDate])
  @@map("plot_crop_seasons")
}

model PlotSoilAnalysis {
  id                  String   @id @default(uuid())
  plotId              String
  farmId              String
  analysisDate        DateTime @db.Date
  labName             String?
  sampleDepthCm       String?
  phH2o               Decimal? @db.Decimal(4, 2)
  organicMatterPct    Decimal? @db.Decimal(5, 2)
  phosphorusMgDm3     Decimal? @db.Decimal(8, 2)
  potassiumMgDm3      Decimal? @db.Decimal(8, 2)
  calciumCmolcDm3     Decimal? @db.Decimal(8, 2)
  magnesiumCmolcDm3   Decimal? @db.Decimal(8, 2)
  aluminumCmolcDm3    Decimal? @db.Decimal(8, 2)
  ctcCmolcDm3         Decimal? @db.Decimal(8, 2)
  baseSaturationPct   Decimal? @db.Decimal(5, 2)
  sulfurMgDm3         Decimal? @db.Decimal(8, 2)
  clayContentPct      Decimal? @db.Decimal(5, 2)
  notes               String?
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  plot    FieldPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)
  farm    Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  creator User      @relation(fields: [createdBy], references: [id])

  @@index([plotId])
  @@index([farmId])
  @@index([analysisDate])
  @@map("plot_soil_analyses")
}

// ─── CAR Registrations ────────────────────────────────────────────

model CarRegistration {
  id                          String     @id @default(uuid())
  farmId                      String
  ruralPropertyId             String?
  carCode                     String
  status                      CarStatus  @default(ATIVO)
  inscriptionDate             DateTime?  @db.Date
  lastRectificationDate       DateTime?  @db.Date

  // Dimensão
  areaHa                      Decimal?   @db.Decimal(12, 4)
  modulosFiscais              Decimal?   @db.Decimal(12, 4)
  city                        String?
  state                       String?    @db.VarChar(2)

  // Cobertura do solo
  nativeVegetationHa          Decimal?   @db.Decimal(12, 4)
  consolidatedAreaHa          Decimal?   @db.Decimal(12, 4)
  administrativeEasementHa    Decimal?   @db.Decimal(12, 4)

  // Reserva Legal
  legalReserveRecordedHa      Decimal?   @db.Decimal(12, 4)
  legalReserveApprovedHa      Decimal?   @db.Decimal(12, 4)
  legalReserveProposedHa      Decimal?   @db.Decimal(12, 4)

  // APP
  appTotalHa                  Decimal?   @db.Decimal(12, 4)
  appConsolidatedHa           Decimal?   @db.Decimal(12, 4)
  appNativeVegetationHa       Decimal?   @db.Decimal(12, 4)

  // Uso restrito
  restrictedUseHa             Decimal?   @db.Decimal(12, 4)

  // Regularidade
  legalReserveSurplusDeficit  Decimal?   @db.Decimal(12, 4)
  legalReserveToRestoreHa     Decimal?   @db.Decimal(12, 4)
  appToRestoreHa              Decimal?   @db.Decimal(12, 4)
  restrictedUseToRestoreHa    Decimal?   @db.Decimal(12, 4)

  // Boundary (PostGIS)
  boundary                    Unsupported("geometry(Polygon, 4326)")?
  boundaryAreaHa              Decimal?   @db.Decimal(12, 4)

  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  farm                        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  ruralProperty               RuralProperty?  @relation(fields: [ruralPropertyId], references: [id], onDelete: SetNull)
  registrationLinks           CarRegistrationLink[]

  @@index([farmId])
  @@index([ruralPropertyId])
  @@index([carCode])
  @@map("car_registrations")
}

model CarRegistrationLink {
  id                  String   @id @default(uuid())
  carRegistrationId   String
  farmRegistrationId  String
  createdAt           DateTime @default(now())

  carRegistration     CarRegistration  @relation(fields: [carRegistrationId], references: [id], onDelete: Cascade)
  farmRegistration    FarmRegistration @relation(fields: [farmRegistrationId], references: [id], onDelete: Cascade)

  @@unique([carRegistrationId, farmRegistrationId])
  @@index([carRegistrationId])
  @@index([farmRegistrationId])
  @@map("car_registration_links")
}

// ─── Rural Property Models ──────────────────────────────────────────

model RuralProperty {
  id                   String    @id @default(uuid())
  farmId               String
  denomination         String
  cib                  String?
  incraCode            String?
  ccirCode             String?
  ccirValidUntil       DateTime? @db.Date
  ccirIssuedAt         DateTime? @db.Date
  ccirGeneratedAt      DateTime? @db.Date
  ccirPaymentStatus    String?
  carCode              String?
  totalAreaHa          Decimal?  @db.Decimal(12, 4)
  registeredAreaHa     Decimal?  @db.Decimal(12, 4)
  possessionByTitleHa  Decimal?  @db.Decimal(12, 4)
  possessionByOccupationHa Decimal? @db.Decimal(12, 4)
  measuredAreaHa       Decimal?  @db.Decimal(12, 4)
  certifiedAreaHa      Decimal?  @db.Decimal(12, 4)
  landClassification   String?
  productive           Boolean?
  locationDirections   String?
  lastProcessingDate   DateTime? @db.Date

  // Fiscal
  fiscalModuleHa       Decimal?  @db.Decimal(12, 4)
  fiscalModulesCount   Decimal?  @db.Decimal(12, 4)
  ruralModuleHa        Decimal?  @db.Decimal(12, 4)
  ruralModulesCount    Decimal?  @db.Decimal(12, 4)
  minPartitionFraction Decimal?  @db.Decimal(12, 4)
  vtnPerHa             Decimal?  @db.Decimal(12, 2)

  // Ambiental
  appAreaHa            Decimal?  @db.Decimal(12, 4)
  legalReserveHa       Decimal?  @db.Decimal(12, 4)
  taxableAreaHa        Decimal?  @db.Decimal(12, 4)
  usableAreaHa         Decimal?  @db.Decimal(12, 4)
  utilizationDegree    Decimal?  @db.Decimal(5, 2)

  // Geo
  municipality         String?
  state                String?   @db.VarChar(2)
  location             Unsupported("geometry(Point, 4326)")?
  boundary             Unsupported("geometry(MultiPolygon, 4326)")?
  boundaryAreaHa       Decimal?  @db.Decimal(12, 4)

  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  farm              Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  titles            FarmRegistration[]
  owners            PropertyOwner[]
  documents         PropertyDocument[]
  fieldPlots        FieldPlot[]
  boundaryVersions  FarmBoundaryVersion[]
  carRegistrations  CarRegistration[]

  @@index([farmId])
  @@map("rural_properties")
}

model PropertyOwner {
  id              String    @id @default(uuid())
  ruralPropertyId String
  name            String
  document        String?
  documentType    String?
  fractionPct     Decimal?  @db.Decimal(5, 2)
  ownerType       OwnerType @default(PROPRIETARIO)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ruralProperty RuralProperty @relation(fields: [ruralPropertyId], references: [id], onDelete: Cascade)

  @@index([ruralPropertyId])
  @@map("property_owners")
}

model PropertyDocument {
  id               String               @id @default(uuid())
  ruralPropertyId  String
  type             PropertyDocumentType
  filename         String
  mimeType         String?
  sizeBytes        Int?
  fileData         Bytes?
  extractedData    Json?
  extractionStatus ExtractionStatus     @default(PENDING)
  uploadedAt       DateTime             @default(now())
  uploadedBy       String?

  ruralProperty RuralProperty @relation(fields: [ruralPropertyId], references: [id], onDelete: Cascade)

  @@index([ruralPropertyId])
  @@index([type])
  @@map("property_documents")
}

// ─── Animal Models ──────────────────────────────────────────────────

model Breed {
  id             String        @id @default(uuid())
  name           String
  code           String?
  species        String        @default("BOVINO")
  category       String        @default("DUPLA_APTIDAO")
  isDefault      Boolean       @default(false)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  compositions   AnimalBreedComposition[]

  @@unique([name, organizationId])
  @@map("breeds")
}

model Animal {
  id                     String          @id @default(uuid())
  farmId                 String
  earTag                 String
  rfidTag                String?
  name                   String?
  registeredName         String?
  registrationNumber     String?
  sex                    AnimalSex
  birthDate              DateTime?       @db.Date
  birthDateEstimated     Boolean         @default(false)
  category               AnimalCategory
  categorySuggested      AnimalCategory?
  origin                 AnimalOrigin    @default(BORN)
  entryWeightKg          Decimal?        @db.Decimal(8, 2)
  bodyConditionScore     Int?
  sireId                 String?
  damId                  String?
  lotId                  String?
  pastureId              String?
  photoUrl               String?
  notes                  String?
  isCompositionEstimated Boolean         @default(false)
  reproductivelyReleased Boolean        @default(false)
  deletedAt              DateTime?
  createdBy              String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  farm         Farm                       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot          AnimalLot?                 @relation(fields: [lotId], references: [id], onDelete: SetNull)
  pasture      FarmLocation?              @relation("AnimalPasture", fields: [pastureId], references: [id], onDelete: SetNull)
  sire         Animal?                    @relation("SireOffspring", fields: [sireId], references: [id], onDelete: SetNull)
  dam          Animal?                    @relation("DamOffspring", fields: [damId], references: [id], onDelete: SetNull)
  sireOffspring Animal[]                  @relation("SireOffspring")
  damOffspring  Animal[]                  @relation("DamOffspring")
  creator      User                       @relation(fields: [createdBy], references: [id])
  compositions AnimalBreedComposition[]
  genealogicalRecords AnimalGenealogicalRecord[]
  lotMovements AnimalLotMovement[]
  weighings    AnimalWeighing[]
  healthRecords AnimalHealthRecord[]
  reproductiveRecords     AnimalReproductiveRecord[]
  plannedSireRecords      AnimalReproductiveRecord[] @relation("PlannedSire")
  sireReproductiveRecords AnimalReproductiveRecord[] @relation("SireReproductive")
  calfRecords             AnimalReproductiveRecord[] @relation("CalfRecord")
  vaccinations            Vaccination[]
  dewormings              Deworming[]
  therapeuticTreatments   TherapeuticTreatment[]
  animalExams             AnimalExam[]
  bullRecord              Bull?                      @relation("BullAnimal")
  reproductiveReleases    ReproductiveRelease[]
  heatRecords             HeatRecord[]
  matingPairs             MatingPair[]
  reproductiveLotAnimals  ReproductiveLotAnimal[]
  inseminations           Insemination[]
  naturalMatingAnimals    NaturalMatingAnimal[]
  pregnancyDiagnoses      PregnancyDiagnosis[]
  calvingsAsMother        CalvingEvent[]         @relation("CalvingMother")
  calvingsAsFather        CalvingEvent[]         @relation("CalvingFather")
  calfRecord              CalvingCalf?           @relation("CalfAnimal")
  calfSeparations         CalfSeparation[]       @relation("SeparatedCalf")
  motherSeparations       CalfSeparation[]       @relation("SeparationMother")
  weaningRecords          WeaningRecord[]        @relation("WeanedCalf")
  milkingRecords          MilkingRecord[]
  milkAnalyses            MilkAnalysis[]
  mastitisCases           MastitisCase[]
  lactations              Lactation[]
  ownerships              AnimalOwnership[]
  animalExit              AnimalExit?

  @@unique([farmId, earTag])
  @@index([farmId])
  @@index([category])
  @@index([sex])
  @@index([sireId])
  @@index([damId])
  @@index([lotId])
  @@map("animals")
}

model AnimalBreedComposition {
  id         String   @id @default(uuid())
  animalId   String
  breedId    String
  fraction   String?
  percentage Decimal  @db.Decimal(5, 2)
  createdAt  DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  breed  Breed  @relation(fields: [breedId], references: [id], onDelete: Restrict)

  @@unique([animalId, breedId])
  @@index([animalId])
  @@map("animal_breed_compositions")
}

model AnimalGenealogicalRecord {
  id                 String         @id @default(uuid())
  animalId           String
  genealogyClass     GenealogyClass
  registrationNumber String?
  associationName    String?
  registrationDate   DateTime?      @db.Date
  girolando_grade    String?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([animalId, genealogyClass])
  @@index([animalId])
  @@map("animal_genealogical_records")
}

// ─── Farm Locations ──────────────────────────────────────────────────

model FarmLocation {
  id              String                                @id @default(uuid())
  farmId          String
  name            String
  type            FarmLocationType
  boundary        Unsupported("geometry(Geometry, 4326)")?
  boundaryAreaHa  Decimal?                              @db.Decimal(12, 4)
  capacityUA      Decimal?                              @db.Decimal(10, 2)
  capacityAnimals Int?
  forageType      ForageType?
  pastureStatus   PastureStatus?
  facilityType    FacilityType?
  facilityStatus  FacilityStatus?
  description     String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime                              @default(now())
  updatedAt       DateTime                              @updatedAt

  farm            Farm                                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lots            AnimalLot[]
  animals         Animal[]                              @relation("AnimalPasture")

  @@index([farmId])
  @@index([type])
  @@map("farm_locations")
}

// ─── Animal Lots ──────────────────────────────────────────────────────

model AnimalLot {
  id                    String          @id @default(uuid())
  farmId                String
  name                  String
  predominantCategory   AnimalCategory
  currentLocation       String
  locationType          LotLocationType
  locationId            String?
  maxCapacity           Int?
  description           String?
  notes                 String?
  deletedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  farm                  Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  location              FarmLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  animals               Animal[]
  movements             AnimalLotMovement[] @relation("LotMovements")
  incomingMovements     AnimalLotMovement[] @relation("PreviousLotMovements")
  dietAssignments       DietLotAssignment[]
  feedingRecords        FeedingRecord[]

  @@index([farmId])
  @@index([predominantCategory])
  @@index([locationId])
  @@map("animal_lots")
}

model AnimalLotMovement {
  id            String    @id @default(uuid())
  animalId      String
  lotId         String
  previousLotId String?
  enteredAt     DateTime  @default(now())
  exitedAt      DateTime?
  movedBy       String
  reason        String?
  createdAt     DateTime  @default(now())

  animal        Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  lot           AnimalLot @relation("LotMovements", fields: [lotId], references: [id], onDelete: Cascade)
  previousLot   AnimalLot? @relation("PreviousLotMovements", fields: [previousLotId], references: [id], onDelete: SetNull)
  mover         User      @relation(fields: [movedBy], references: [id])

  @@index([animalId])
  @@index([lotId])
  @@index([enteredAt])
  @@index([exitedAt])
  @@map("animal_lot_movements")
}

// ─── Animal Weighings ──────────────────────────────────────────────

model AnimalWeighing {
  id                 String   @id @default(uuid())
  animalId           String
  farmId             String
  weightKg           Decimal  @db.Decimal(8, 2)
  measuredAt         DateTime @db.Date
  bodyConditionScore Int?
  notes              String?
  recordedBy         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm     Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  recorder User   @relation(fields: [recordedBy], references: [id])

  @@index([animalId])
  @@index([farmId])
  @@index([measuredAt])
  @@map("animal_weighings")
}

// ─── Animal Health Records ──────────────────────────────────────────

model AnimalHealthRecord {
  id                String            @id @default(uuid())
  animalId          String
  farmId            String
  type              HealthEventType
  eventDate         DateTime          @db.Date
  productName       String?
  dosage            String?
  applicationMethod ApplicationMethod?
  batchNumber       String?
  diagnosis         String?
  durationDays      Int?
  withdrawalDays    Int?
  examResult        String?
  labName           String?
  isFieldExam       Boolean?          @default(false)
  veterinaryName    String?
  notes             String?
  recordedBy        String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm     Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  recorder User   @relation(fields: [recordedBy], references: [id])

  @@index([animalId])
  @@index([farmId])
  @@index([eventDate])
  @@index([type])
  @@map("animal_health_records")
}

// ─── Animal Reproductive Records ──────────────────────────────────

model AnimalReproductiveRecord {
  id                   String                 @id @default(uuid())
  animalId             String
  farmId               String
  type                 ReproductiveEventType
  eventDate            DateTime               @db.Date
  notes                String?
  recordedBy           String

  // CLEARANCE
  approvedBy           String?
  criteriaDetails      String?

  // HEAT
  heatIntensity        HeatIntensity?
  intervalDays         Int?

  // BREEDING_PLAN
  plannedSireId        String?
  breedingMethod       BreedingMethod?
  plannedDate          DateTime?              @db.Date

  // AI
  sireId               String?
  sireName             String?
  semenBatch           String?
  technicianName       String?

  // PREGNANCY
  confirmationMethod   PregnancyConfirmation?
  confirmationDate     DateTime?              @db.Date
  expectedDueDate      DateTime?              @db.Date

  // CALVING
  calvingType          CalvingType?
  calvingComplications String?
  calfId               String?
  calfSex              AnimalSex?
  calfWeightKg         Decimal?               @db.Decimal(8, 2)

  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  animal       Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm         Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  recorder     User   @relation(fields: [recordedBy], references: [id])
  plannedSire  Animal? @relation("PlannedSire", fields: [plannedSireId], references: [id], onDelete: SetNull)
  sire         Animal? @relation("SireReproductive", fields: [sireId], references: [id], onDelete: SetNull)
