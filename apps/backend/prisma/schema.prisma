  @@index([lotId])
  @@index([scheduledDate])
  @@map("reproductive_lot_steps")
}

model Insemination {
  id                    String    @id @default(uuid())
  organizationId        String
  farmId                String
  animalId              String
  lotStepId             String?
  inseminationType      String    // IATF, NATURAL_HEAT, HEAT_DURING_PROTOCOL
  bullId                String?
  semenBatchId          String?
  dosesUsed             Int       @default(1)
  inseminatorName       String
  inseminationDate      DateTime  @db.Date
  inseminationTime      String?   // HH:MM or period
  cervicalMucus         String?   // CRYSTALLINE, CLOUDY, BLOODY, PURULENT, ABSENT
  heatRecordId          String?   // link to heat record if natural heat
  matingPairId          String?   // link to mating plan pair
  plannedBullId         String?   // from mating plan
  wasPlannedBull        Boolean?  // did they use the planned bull?
  substitutionReason    String?
  observations          String?
  stockOutputId         String?   // semen + hormone stock deduction
  recordedBy            String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  farm          Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal        Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  lotStep       ReproductiveLotStep? @relation(fields: [lotStepId], references: [id], onDelete: SetNull)
  bull          Bull?            @relation("InseminationBull", fields: [bullId], references: [id], onDelete: SetNull)
  semenBatch    SemenBatch?      @relation(fields: [semenBatchId], references: [id], onDelete: SetNull)
  recorder      User             @relation("InseminationRecorder", fields: [recordedBy], references: [id])

  @@index([organizationId])
  @@index([farmId])
  @@index([animalId])
  @@index([lotStepId])
  @@index([inseminationDate])
  @@map("inseminations")
}

// ─── EPIC-12 US-114: Monta Natural ──────────────────────────────────

enum NaturalMatingReason {
