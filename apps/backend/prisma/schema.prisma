generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ─── Enums ───────────────────────────────────────────────────────────

enum OrganizationType {
  PF
  PJ
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGRONOMIST
  FINANCIAL
  OPERATOR
  COWBOY
  CONSULTANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum FarmStatus {
  ACTIVE
  INACTIVE
}

enum ProducerType {
  PF
  PJ
  SOCIEDADE_EM_COMUM
}

enum ProducerStatus {
  ACTIVE
  INACTIVE
}

enum ProducerFarmBondType {
  PROPRIETARIO
  ARRENDATARIO
  COMODATARIO
  PARCEIRO
  MEEIRO
  USUFRUTUARIO
  CONDOMINO
}

enum TaxRegime {
  REAL
  PRESUMIDO
  SIMPLES
  ISENTO
}

enum IeSituation {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum IeCategory {
  PRIMEIRO_ESTABELECIMENTO
  DEMAIS
  UNICO
}

enum SeasonType {
  SAFRA
  SAFRINHA
  INVERNO
}

enum CarStatus {
  ATIVO
  PENDENTE
  CANCELADO
  SUSPENSO
}

enum AnimalSex {
  MALE
  FEMALE
}

enum AnimalCategory {
  BEZERRO
  BEZERRA
  NOVILHA
  NOVILHO
  VACA_LACTACAO
  VACA_SECA
  TOURO_REPRODUTOR
  DESCARTE
}

enum AnimalOrigin {
  BORN
  PURCHASED
}

enum GenealogyClass {
  PO
  PC_OC
  PC_OD
  GC_01
  GC_02
  GC_03
  PA
  LA
  CCG
  SRD
}

enum LotLocationType {
  PASTO
  GALPAO
  BEZERREIRO
  CURRAL
  BAIA
  CONFINAMENTO
  OUTRO
}

enum SoilType {
  LATOSSOLO_VERMELHO
  LATOSSOLO_AMARELO
  ARGISSOLO
  NEOSSOLO
  CAMBISSOLO
  GLEISSOLO
  PLANOSSOLO
  NITOSSOLO
  OUTRO
}

enum FarmLocationType {
  PASTURE
  FACILITY
}

enum PastureStatus {
  EM_USO
  DESCANSO
  REFORMANDO
}

enum FacilityStatus {
  ATIVO
  MANUTENCAO
  INATIVO
}

enum ForageType {
  BRACHIARIA_BRIZANTHA
  BRACHIARIA_DECUMBENS
  BRACHIARIA_HUMIDICOLA
  PANICUM_MAXIMUM
  PANICUM_MOMBASA
  PANICUM_TANZANIA
  CYNODON_TIFTON
  CYNODON_COASTCROSS
  PENNISETUM_NAPIER
  ANDROPOGON
  ESTILOSANTES
  OUTRO
}

enum FacilityType {
  GALPAO
  BEZERREIRO
  CURRAL
  BAIA
  SALA_ORDENHA
  ESTABULO
  CONFINAMENTO
  OUTRO
}

enum HealthEventType {
  VACCINATION
  DEWORMING
  TREATMENT
  EXAM
}

enum ApplicationMethod {
  INJECTABLE
  ORAL
  POUR_ON
  OTHER
}

enum ReproductiveEventType {
  CLEARANCE
  HEAT
  BREEDING_PLAN
  AI
  PREGNANCY
  CALVING
}

enum HeatIntensity {
  WEAK
  MODERATE
  STRONG
}

enum BreedingMethod {
  NATURAL
  AI
  ET
}

enum CalvingType {
  NORMAL
  ASSISTED
  CESAREAN
  DYSTOCIC
}

enum PregnancyConfirmation {
  PALPATION
  ULTRASOUND
  BLOOD_TEST
  OBSERVATION
}

// ─── Core Models ─────────────────────────────────────────────────────

model Organization {
  id        String           @id @default(uuid())
  name      String
  type      OrganizationType
  document  String           @unique
  plan      String           @default("basic")
  status    OrgStatus        @default(ACTIVE)
  maxUsers  Int              @default(10)
  maxFarms  Int              @default(5)
  allowMultipleSessions Boolean @default(true)
  allowSocialLogin     Boolean @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  users       User[]
  farms       Farm[]
  customRoles CustomRole[]
  producers   Producer[]
  breeds      Breed[]
  cultivars           Cultivar[]
  moistureStandards   MoistureStandard[]
  grainDiscountTables GrainDiscountTable[]
  grainClassifications GrainClassification[]
  pests           Pest[]
  operationTypes            OperationType[]
  cropOperationSequences    CropOperationSequence[]
  operationTypeSchedules    OperationTypeSchedule[]
  cropPhenologicalStages    CropPhenologicalStage[]
  measurementUnits          MeasurementUnit[]
  unitConversions           UnitConversion[]
  productUnitConfigs        ProductUnitConfig[]
  products                  Product[]
  manufacturers             Manufacturer[]
  stockEntries              StockEntry[]
  stockBalances             StockBalance[]
  stockOutputs              StockOutput[]
  stockInventories          StockInventory[]
  stockAdjustments          StockAdjustment[]
  pesticidePrescriptions    PesticidePrescription[]
  diseases                  Disease[]
  treatmentProtocols        TreatmentProtocol[]
  sanitaryProtocols         SanitaryProtocol[]
  vaccinations              Vaccination[]
  dewormings                Deworming[]
  therapeuticTreatments     TherapeuticTreatment[]
  examTypes                ExamType[]
  animalExams              AnimalExam[]
  compositeProductions     CompositeProduction[]
  bulls                    Bull[]
  semenBatches             SemenBatch[]
  reproductiveReleases     ReproductiveRelease[]
  reproductiveCriteria     ReproductiveCriteria?
  heatRecords              HeatRecord[]
  matingPlans              MatingPlan[]
  iatfProtocols            IatfProtocol[]
  reproductiveLots         ReproductiveLot[]
  inseminations            Insemination[]
  naturalMatings           NaturalMating[]
  pregnancyDiagnoses       PregnancyDiagnosis[]
  calvingEvents            CalvingEvent[]
  calfSeparations          CalfSeparation[]
  weaningRecords           WeaningRecord[]
  weaningCriteria          WeaningCriteria?
  milkingRecords           MilkingRecord[]
  milkAnalyses             MilkAnalysis[]
  milkQualityConfig        MilkQualityConfig?
  mastitisCases            MastitisCase[]
  coolingTanks             CoolingTank[]
  milkCollections          MilkCollection[]
  lactations               Lactation[]
  feedIngredients          FeedIngredient[]
  bromatologicalAnalyses   BromatologicalAnalysis[]
  diets                    Diet[]
  feedingRecords           FeedingRecord[]
  bankAccounts             BankAccount[]
  bankAccountBalances      BankAccountBalance[]
  financialTransactions    FinancialTransaction[]
  payables                 Payable[]
  receivables              Receivable[]
  accountTransfers         AccountTransfer[]
  creditCards              CreditCard[]
  creditCardBills          CreditCardBill[]
  creditCardExpenses       CreditCardExpense[]
  checks                   Check[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String
  passwordHash   String?
  phone          String?
  googleId       String?    @unique
  role           UserRole   @default(OPERATOR)
  status         UserStatus @default(ACTIVE)
  hourlyRate     Decimal?   @map("hourly_rate") @db.Decimal(10, 2)
  lastLoginAt    DateTime?
  organizationId String?
  customRoleId   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization      Organization?         @relation(fields: [organizationId], references: [id])
  customRole        CustomRole?           @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  farmAccess                UserFarmAccess[]
  boundaryUploads           FarmBoundaryVersion[]
  plotBoundaryEdits         FieldPlotBoundaryVersion[]
  createdCropSeasons        PlotCropSeason[]
  createdSoilAnalyses       PlotSoilAnalysis[]
  createdAnimals            Animal[]
  lotMovements              AnimalLotMovement[]
  recordedWeighings         AnimalWeighing[]
  recordedHealthRecords     AnimalHealthRecord[]
  recordedReproductiveRecords AnimalReproductiveRecord[]
  recordedFieldOperations     FieldOperation[]
  recordedPesticideApplications PesticideApplication[] @relation("PesticideRecorder")
  recordedFertilizerApplications FertilizerApplication[] @relation("FertilizerRecorder")
  recordedCulturalOperations CulturalOperation[] @relation("CulturalOperationRecorder")
  recordedSoilPrepOperations SoilPrepOperation[] @relation("SoilPrepRecorder")
  ledTeams                   FieldTeam[]         @relation("TeamLeader")
  createdTeams               FieldTeam[]         @relation("TeamCreator")
  teamMemberships            FieldTeamMember[]
  recordedTeamOperations     TeamOperation[]     @relation("TeamOperationRecorder")
  teamOperationEntries       TeamOperationEntry[] @relation("TeamOperationEntryWorker")
  phenologicalRecords        PlotPhenologicalRecord[]
  recordedPlantingOperations PlantingOperation[]      @relation("PlantingRecorder")
  recordedGrainHarvests      GrainHarvest[]           @relation("GrainHarvestRecorder")
  recordedCoffeeHarvests     CoffeeHarvest[]          @relation("CoffeeHarvestRecorder")
  recordedOrangeHarvests     OrangeHarvest[]          @relation("OrangeHarvestRecorder")
  createdPrescriptions       PesticidePrescription[]  @relation("PrescriptionCreator")
  recordedVaccinations       Vaccination[]            @relation("VaccinationRecorder")
  recordedDewormings         Deworming[]              @relation("DewormingRecorder")
  recordedTreatments         TherapeuticTreatment[]   @relation("TreatmentRecorder")
  recordedEvolutions         ClinicalEvolution[]      @relation("EvolutionRecorder")
  recordedExams              AnimalExam[]             @relation("ExamRecorder")
  recordedCompositeProductions CompositeProduction[]  @relation("CompositeProductionRecorder")
  recordedReleases             ReproductiveRelease[]  @relation("ReleaseRecorder")
  recordedHeats                HeatRecord[]           @relation("HeatRecorder")
  createdMatingPlans           MatingPlan[]           @relation("MatingPlanCreator")
  createdIatfProtocols         IatfProtocol[]         @relation("IatfProtocolCreator")
  createdReproductiveLots      ReproductiveLot[]      @relation("ReproductiveLotCreator")
  recordedInseminations        Insemination[]         @relation("InseminationRecorder")
  recordedNaturalMatings       NaturalMating[]        @relation("NaturalMatingRecorder")
  recordedDiagnoses            PregnancyDiagnosis[]   @relation("DgRecorder")
  recordedCalvings             CalvingEvent[]         @relation("CalvingRecorder")
  recordedSeparations          CalfSeparation[]       @relation("SeparationRecorder")
  recordedWeanings             WeaningRecord[]        @relation("WeaningRecorder")
  recordedMilkings             MilkingRecord[]        @relation("MilkingRecorder")
  recordedMilkAnalyses         MilkAnalysis[]         @relation("MilkAnalysisRecorder")
  recordedMastitisCases        MastitisCase[]         @relation("MastitisRecorder")
  recordedTankMeasurements     TankMeasurement[]      @relation("TankMeasurementRecorder")
  recordedMilkCollections      MilkCollection[]       @relation("MilkCollectionRecorder")
  recordedLactations           Lactation[]            @relation("LactationRecorder")
  recordedBromatologicalAnalyses BromatologicalAnalysis[] @relation("BromatologicalRecorder")
  createdDiets                   Diet[]                   @relation("DietCreator")
  recordedFeedings               FeedingRecord[]          @relation("FeedingRecorder")

  @@map("users")
}

model Farm {
  id                   String                                @id @default(uuid())
  name                 String
  nickname             String?
  address              String?
  city                 String?
  state                String
  zipCode              String?
  totalAreaHa          Decimal                               @db.Decimal(12, 4)
  cib                  String?
  incraCode            String?
  carCode              String?
  ccirCode             String?
  landClassification   String?
  productive           Boolean?
  fiscalModuleHa       Decimal?                              @db.Decimal(12, 4)
  fiscalModulesCount   Decimal?                              @db.Decimal(12, 4)
  minPartitionFraction Decimal?                              @db.Decimal(12, 4)
  appAreaHa            Decimal?                              @db.Decimal(12, 4)
  legalReserveHa       Decimal?                              @db.Decimal(12, 4)
  taxableAreaHa        Decimal?                              @db.Decimal(12, 4)
  usableAreaHa         Decimal?                              @db.Decimal(12, 4)
  utilizationDegree    Decimal?                              @db.Decimal(5, 2)
  status               FarmStatus                            @default(ACTIVE)
  organizationId       String
  boundaryAreaHa       Decimal?                              @db.Decimal(12, 4)
  location             Unsupported("geometry(Point, 4326)")?
  boundary             Unsupported("geometry(Polygon, 4326)")?
  deletedAt            DateTime?
  createdAt            DateTime                              @default(now())
  updatedAt            DateTime                              @updatedAt

  organization            Organization              @relation(fields: [organizationId], references: [id])
  userAccess              UserFarmAccess[]
  registrations           FarmRegistration[]
  documents               FarmDocument[]
  producerFarmLinks       ProducerFarmLink[]
  producerStateRegistrations ProducerStateRegistration[]
  boundaryVersions           FarmBoundaryVersion[]
  fieldPlots                 FieldPlot[]
  fieldPlotBoundaryVersions  FieldPlotBoundaryVersion[]
  plotCropSeasons            PlotCropSeason[]
  plotSoilAnalyses           PlotSoilAnalysis[]
  carRegistrations           CarRegistration[]
  animals                    Animal[]
  animalLots                 AnimalLot[]
  farmLocations              FarmLocation[]
  animalWeighings            AnimalWeighing[]
  animalHealthRecords        AnimalHealthRecord[]
  animalReproductiveRecords  AnimalReproductiveRecord[]
  fieldOperations            FieldOperation[]
  pesticideApplications      PesticideApplication[]
  fertilizerApplications     FertilizerApplication[]
  culturalOperations         CulturalOperation[]
  soilPrepOperations         SoilPrepOperation[]
  fieldTeams                 FieldTeam[]
  teamOperations             TeamOperation[]
  productivityTargets        ProductivityTarget[]
  monitoringPoints           MonitoringPoint[]
  monitoringRecords          MonitoringRecord[]
  plantingOperations         PlantingOperation[]
  grainHarvests              GrainHarvest[]
  coffeeHarvests             CoffeeHarvest[]
  orangeHarvests             OrangeHarvest[]
  stockEntries               StockEntry[]
  stockOutputsAsSource       StockOutput[] @relation("SourceFarmOutputs")
  stockOutputsAsDestination  StockOutput[] @relation("DestinationFarmOutputs")
  stockInventories           StockInventory[]
  pesticidePrescriptions     PesticidePrescription[]
  costCenters                CostCenter[]
  vaccinations               Vaccination[]
  dewormings                 Deworming[]
  therapeuticTreatments      TherapeuticTreatment[]
  animalExams                AnimalExam[]
  bulls                      Bull[]
  reproductiveReleases       ReproductiveRelease[]
  heatRecords                HeatRecord[]
  matingPlans                MatingPlan[]
  reproductiveLots           ReproductiveLot[]
  inseminations              Insemination[]
  naturalMatings             NaturalMating[]
  pregnancyDiagnoses         PregnancyDiagnosis[]
  calvingEvents              CalvingEvent[]
  calfSeparations            CalfSeparation[]
  weaningRecords             WeaningRecord[]
  milkingRecords             MilkingRecord[]
  milkAnalyses               MilkAnalysis[]
  mastitisCases              MastitisCase[]
  coolingTanks               CoolingTank[]
  milkCollections            MilkCollection[]
  lactations                 Lactation[]
  feedingRecords             FeedingRecord[]
  bankAccountFarms           BankAccountFarm[]
  payables                   Payable[]
  receivables                Receivable[]
  payableCostCenterItems     PayableCostCenterItem[]
  receivableCostCenterItems  ReceivableCostCenterItem[]
  creditCards                CreditCard[]

  @@map("farms")
}

model FarmRegistration {
  id               String    @id @default(uuid())
  farmId           String
  number           String
  cnsCode          String?
  cartorioName     String
  comarca          String
  state            String    @db.VarChar(2)
  livro            String?
  registrationDate DateTime?
  areaHa           Decimal   @db.Decimal(12, 4)
  boundaryAreaHa   Decimal?  @db.Decimal(12, 4)
  boundary         Unsupported("geometry(Polygon, 4326)")?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  farm              Farm                      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  producerLinks     ProducerRegistrationLink[]
  boundaryVersions  FarmBoundaryVersion[]
  fieldPlots        FieldPlot[]
  carLinks          CarRegistrationLink[]

  @@index([farmId])
  @@map("farm_registrations")
}

model FarmDocument {
  id        String   @id @default(uuid())
  farmId    String
  type      String
  filename  String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@map("farm_documents")
}

model UserFarmAccess {
  id     String @id @default(uuid())
  userId String
  farmId String

  user User @relation(fields: [userId], references: [id])
  farm Farm @relation(fields: [farmId], references: [id])

  @@unique([userId, farmId])
  @@map("user_farm_access")
}

model CustomRole {
  id             String   @id @default(uuid())
  name           String
  description    String?
  baseRole       UserRole
  organizationId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  permissions  RolePermission[]
  users        User[]

  @@unique([name, organizationId])
  @@map("custom_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  customRoleId String
  module       String
  action       String
  allowed      Boolean @default(true)

  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, module, action])
  @@map("role_permissions")
}

model AuditLog {
  id             String   @id @default(uuid())
  actorId        String
  actorEmail     String
  actorRole      UserRole
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  farmId         String?
  organizationId String?
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([farmId])
  @@index([organizationId])
  @@map("audit_logs")
}

model FarmBoundaryVersion {
  id              String    @id @default(uuid())
  farmId          String
  registrationId  String?
  boundary        Unsupported("geometry(Polygon, 4326)")
  boundaryAreaHa  Decimal   @db.Decimal(12, 4)
  uploadedBy      String
  uploadedAt      DateTime  @default(now())
  filename        String?
  version         Int       @default(1)

  farm         Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  registration FarmRegistration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  uploader     User              @relation(fields: [uploadedBy], references: [id])

  @@index([farmId])
  @@index([registrationId])
  @@map("farm_boundary_versions")
}

// ─── Producer Models ────────────────────────────────────────────────

model Producer {
  id                  String         @id @default(uuid())
  organizationId      String
  type                ProducerType
  name                String
  tradeName           String?
  document            String?
  birthDate           DateTime?
  spouseCpf           String?
  incraRegistration   String?
  legalRepresentative String?
  legalRepCpf         String?
  address             String?
  city                String?
  state               String?
  zipCode             String?
  taxRegime           TaxRegime?
  mainCnae            String?
  ruralActivityType   String?
  status              ProducerStatus @default(ACTIVE)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization       Organization              @relation(fields: [organizationId], references: [id])
  participants       SocietyParticipant[]
  stateRegistrations ProducerStateRegistration[]
  farmLinks          ProducerFarmLink[]
  documents          ProducerDocument[]
  bankAccounts       BankAccount[]
  payables           Payable[]
  receivables        Receivable[]

  @@unique([document, organizationId])
  @@index([organizationId])
  @@map("producers")
}

model SocietyParticipant {
  id               String   @id @default(uuid())
  producerId       String
  name             String
  cpf              String
  participationPct Decimal  @db.Decimal(5, 2)
  isMainResponsible Boolean @default(false)
  createdAt        DateTime @default(now())

  producer Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@unique([producerId, cpf])
  @@index([producerId])
  @@map("society_participants")
}

model ProducerStateRegistration {
  id               String       @id @default(uuid())
  producerId       String
  farmId           String?
  number           String
  state            String       @db.VarChar(2)
  cnaeActivity     String?
  assessmentRegime String?
  category         IeCategory?
  inscriptionDate  DateTime?
  situation        IeSituation  @default(ACTIVE)
  contractEndDate  DateTime?
  milkProgramOptIn Boolean      @default(false)
  isDefaultForFarm Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  producer Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  farm     Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)

  @@unique([producerId, number, state])
  @@index([producerId])
  @@index([farmId])
  @@map("producer_state_registrations")
}

model ProducerFarmLink {
  id               String              @id @default(uuid())
  producerId       String
  farmId           String
  bondType         ProducerFarmBondType
  participationPct Decimal?            @db.Decimal(5, 2)
  startDate        DateTime?
  endDate          DateTime?
  isItrDeclarant   Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  producer          Producer                  @relation(fields: [producerId], references: [id], onDelete: Cascade)
  farm              Farm                      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  registrationLinks ProducerRegistrationLink[]

  @@unique([producerId, farmId, bondType])
  @@index([producerId])
  @@index([farmId])
  @@index([endDate])
  @@map("producer_farm_links")
}

model ProducerRegistrationLink {
  id                 String   @id @default(uuid())
  farmLinkId         String
  farmRegistrationId String
  createdAt          DateTime @default(now())

  farmLink         ProducerFarmLink @relation(fields: [farmLinkId], references: [id], onDelete: Cascade)
  farmRegistration FarmRegistration  @relation(fields: [farmRegistrationId], references: [id], onDelete: Cascade)

  @@unique([farmLinkId, farmRegistrationId])
  @@index([farmLinkId])
  @@index([farmRegistrationId])
  @@map("producer_registration_links")
}

model ProducerDocument {
  id         String   @id @default(uuid())
  producerId String
  type       String
  filename   String
  url        String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  producer Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@index([producerId])
  @@map("producer_documents")
}

// ─── Field Plots ────────────────────────────────────────────────────

model FieldPlot {
  id              String    @id @default(uuid())
  farmId          String
  registrationId  String?
  name            String
  code            String?
  soilType        SoilType?
  currentCrop     String?
  previousCrop    String?
  notes           String?
  boundary        Unsupported("geometry(Polygon, 4326)")
  boundaryAreaHa  Decimal   @db.Decimal(12, 4)
  status          String    @default("ACTIVE")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farm              Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  registration      FarmRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  boundaryVersions  FieldPlotBoundaryVersion[]
  cropSeasons            PlotCropSeason[]
  soilAnalyses           PlotSoilAnalysis[]
  pesticideApplications  PesticideApplication[]
  fertilizerApplications FertilizerApplication[]
  culturalOperations     CulturalOperation[]
  soilPrepOperations     SoilPrepOperation[]
  teamOperations         TeamOperation[]
  monitoringPoints       MonitoringPoint[]
  monitoringRecords      MonitoringRecord[]
  phenologicalRecords    PlotPhenologicalRecord[]
  plantingOperations     PlantingOperation[]
  grainHarvests          GrainHarvest[]
  coffeeHarvests         CoffeeHarvest[]
  orangeHarvests             OrangeHarvest[]
  pesticidePrescriptions     PesticidePrescription[]

  @@index([farmId])
  @@index([registrationId])
  @@map("field_plots")
}

model FieldPlotBoundaryVersion {
  id              String    @id @default(uuid())
  plotId          String
  farmId          String
  boundary        Unsupported("geometry(Polygon, 4326)")
  boundaryAreaHa  Decimal   @db.Decimal(12, 4)
  editedBy        String
  editedAt        DateTime  @default(now())
  editSource      String    @default("file_upload")
  version         Int       @default(1)

  plot     FieldPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)
  farm     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  editor   User      @relation(fields: [editedBy], references: [id])

  @@index([plotId])
  @@index([farmId])
  @@map("field_plot_boundary_versions")
}

// ─── Plot Usage History ────────────────────────────────────────────

model PlotCropSeason {
  id                String     @id @default(uuid())
  plotId            String
  farmId            String
  cultivarId        String?
  seasonType        SeasonType
  seasonYear        String
  crop              String
  varietyName       String?
  startDate         DateTime?  @db.Date
  endDate           DateTime?  @db.Date
  plantedAreaHa     Decimal?   @db.Decimal(12, 4)
  productivityKgHa  Decimal?   @db.Decimal(12, 2)
